<inf:GlassWindow x:Class="Delp.App.Windows.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:inf="clr-namespace:Delp.App.Infrastructure"
                 Title="Delp"
                 Width="1120" Height="740"
                 MinWidth="780" MinHeight="500"
                 Icon="pack://application:,,,/Assets/delp.ico"
                 WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="42" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom title bar -->
        <DockPanel Grid.Row="0" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                <Image Source="{StaticResource Logo.Drawing}" Width="17" Height="17" />
                <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold" Text="Delp" />
                <TextBlock Margin="10,1,0,0"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{StaticResource Brush.Fg2}"
                           Text="developer toolbox" />
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right" Orientation="Horizontal">
                <Button Style="{StaticResource Button.TitleBar}" Content="&#xE921;" ToolTip="Minimize" Click="Minimize_Click" />
                <Button Style="{StaticResource Button.TitleBarClose}" Content="&#xE8BB;" ToolTip="Hide to tray" Click="Close_Click" />
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="272" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <DockPanel Grid.Column="0" Margin="12,2,4,12">
                <Button x:Name="AboutBtn"
                        DockPanel.Dock="Bottom"
                        Style="{StaticResource Button.Icon}"
                        HorizontalAlignment="Left"
                        Margin="4,8,4,0"
                        Padding="6,3"
                        FontSize="11"
                        Foreground="{StaticResource Brush.Fg2}"
                        ToolTip="About Delp"
                        Click="About_Click" />
                <TextBox x:Name="SearchBox"
                         DockPanel.Dock="Top"
                         Style="{StaticResource TextBox.Search}"
                         Tag="Search tools…   Ctrl+F"
                         Margin="4,0,4,10"
                         TextChanged="SearchBox_TextChanged" />
                <ListBox x:Name="NavList"
                         Padding="4,0"
                         IsSynchronizedWithCurrentItem="False"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         SelectionChanged="NavList_SelectionChanged">
                    <ListBox.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.ContainerStyle>
                                <Style TargetType="GroupItem">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="GroupItem">
                                                <StackPanel>
                                                    <ToggleButton x:Name="HeaderToggle"
                                                                  Style="{StaticResource NavGroupHeader}"
                                                                  Content="{Binding Name}"
                                                                  IsChecked="True"
                                                                  Loaded="GroupToggle_Loaded"
                                                                  Checked="GroupToggle_Changed"
                                                                  Unchecked="GroupToggle_Changed" />
                                                    <ItemsPresenter Visibility="{Binding IsChecked, ElementName=HeaderToggle, Converter={StaticResource BoolToVis}}" />
                                                </StackPanel>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </GroupStyle.ContainerStyle>
                        </GroupStyle>
                    </ListBox.GroupStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock FontSize="13" Text="{Binding Name}" />
                                <TextBlock FontSize="11"
                                           Foreground="{StaticResource Brush.Fg2}"
                                           Text="{Binding Description}"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <!-- Tool host -->
            <Border Grid.Column="1" Style="{StaticResource Card}" Margin="4,2,12,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid x:Name="HeaderPanel" Grid.Row="0" Margin="20,16,20,0" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock x:Name="ToolTitle" Style="{StaticResource Text.Title}" />
                            <TextBlock x:Name="ToolDesc" Style="{StaticResource Text.Sub}" Margin="0,2,0,0" />
                        </StackPanel>
                        <Button x:Name="StarBtn"
                                Grid.Column="1"
                                Style="{StaticResource Button.Icon}"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="14"
                                VerticalAlignment="Top"
                                Content="&#xE734;"
                                ToolTip="Add to favorites"
                                Click="Star_Click" />
                    </Grid>

                    <ContentControl x:Name="ToolHost" Grid.Row="1" Margin="4" />

                    <StackPanel x:Name="Welcome"
                                Grid.Row="0" Grid.RowSpan="2"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <Image Source="{StaticResource Logo.Drawing}"
                               Width="84" Height="84"
                               HorizontalAlignment="Center"
                               Opacity="0.95" />
                        <TextBlock Margin="0,18,0,0"
                                   HorizontalAlignment="Center"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Text="Delp" />
                        <TextBlock x:Name="WelcomeHint"
                                   Margin="0,8,0,0"
                                   HorizontalAlignment="Center"
                                   Foreground="{StaticResource Brush.Fg1}"
                                   Text="Pick a tool from the sidebar, or press Ctrl+Alt+Space anywhere for the quick panel." />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</inf:GlassWindow>
