<inf:GlassWindow x:Class="Delp.App.Windows.AboutWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:inf="clr-namespace:Delp.App.Infrastructure"
                 Title="About Delp"
                 Width="440" Height="500"
                 ResizeMode="NoResize"
                 ShowInTaskbar="False"
                 WindowStartupLocation="CenterOwner">
    <DockPanel Margin="20" MouseLeftButtonDown="Root_MouseLeftButtonDown" Background="Transparent">

        <DockPanel DockPanel.Dock="Top">
            <Button DockPanel.Dock="Right"
                    Style="{StaticResource Button.Icon}"
                    Content="&#xE8BB;"
                    FontFamily="Segoe MDL2 Assets"
                    FontSize="11"
                    VerticalAlignment="Top"
                    ToolTip="Close (Esc)"
                    Click="Close_Click" />
            <StackPanel Orientation="Horizontal">
                <Image Source="{StaticResource Logo.Drawing}" Width="44" Height="44" VerticalAlignment="Center" />
                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource Text.Title}" Text="Delp" />
                    <TextBlock x:Name="VersionText" Style="{StaticResource Text.Sub}" />
                </StackPanel>
            </StackPanel>
        </DockPanel>

        <TextBlock DockPanel.Dock="Top"
                   Margin="0,14,0,0"
                   Style="{StaticResource Text.Sub}"
                   Text="A native Windows developer toolbox. Fully offline, tray-first — press Ctrl+Alt+Space anywhere." />

        <Border DockPanel.Dock="Top" Style="{StaticResource Card}" Margin="0,14,0,0" Padding="14,10">
            <StackPanel x:Name="MetaRows" />
        </Border>

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,14,0,0">
            <Button Content="GitHub" Click="GitHub_Click" Margin="0,0,8,0" />
            <Button Content="Report an issue" Click="Issues_Click" Margin="0,0,8,0" />
            <Button x:Name="CopyInfoBtn" Content="Copy info" Click="CopyInfo_Click" />
        </StackPanel>

        <TextBlock DockPanel.Dock="Bottom"
                   x:Name="LicenseText"
                   Style="{StaticResource Text.Sub}"
                   Foreground="{StaticResource Brush.Fg2}" />
        <TextBlock DockPanel.Dock="Bottom"
                   Margin="0,0,0,4"
                   Style="{StaticResource Text.Sub}"
                   Foreground="{StaticResource Brush.Fg2}"
                   TextWrapping="Wrap"
                   Text="Built with AvalonEdit, Roslyn, NUglify, YamlDotNet, QRCoder, DiffPlex, Markdig and friends." />
        <Border />
    </DockPanel>
</inf:GlassWindow>
