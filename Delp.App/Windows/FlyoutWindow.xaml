<inf:GlassWindow x:Class="Delp.App.Windows.FlyoutWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:inf="clr-namespace:Delp.App.Infrastructure"
                 Title="Delp"
                 Width="430" Height="620"
                 ResizeMode="NoResize"
                 ShowInTaskbar="False"
                 Topmost="True"
                 WindowStartupLocation="Manual"
                 Visibility="Hidden">
    <DockPanel Margin="14">

        <Grid DockPanel.Dock="Top" Margin="4,2,2,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button x:Name="BackBtn"
                    Grid.Column="0"
                    Style="{StaticResource Button.Icon}"
                    Content="&#xE72B;"
                    FontFamily="Segoe MDL2 Assets"
                    FontSize="12"
                    Margin="0,0,6,0"
                    Visibility="Collapsed"
                    ToolTip="Back to tool list (Esc)"
                    Click="Back_Click" />
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Image Source="{StaticResource Logo.Drawing}" Width="17" Height="17" />
                <TextBlock x:Name="HeaderText"
                           Margin="8,0,0,0"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Text="Delp" />
            </StackPanel>
            <Button x:Name="StarBtn"
                    Grid.Column="2"
                    Style="{StaticResource Button.Icon}"
                    Content="&#xE734;"
                    FontFamily="Segoe MDL2 Assets"
                    FontSize="12"
                    Visibility="Collapsed"
                    ToolTip="Add to favorites"
                    Click="Star_Click" />
            <Button x:Name="ExpandBtn"
                    Grid.Column="3"
                    Style="{StaticResource Button.Icon}"
                    Content="&#xE740;"
                    FontFamily="Segoe MDL2 Assets"
                    FontSize="12"
                    ToolTip="Open in full app"
                    Click="Expand_Click" />
        </Grid>

        <TextBox x:Name="SearchBox"
                 DockPanel.Dock="Top"
                 Style="{StaticResource TextBox.Search}"
                 Tag="Search 50 tools…"
                 Margin="2,0,2,10"
                 TextChanged="SearchBox_TextChanged"
                 KeyDown="SearchBox_KeyDown" />

        <Grid>
            <ListBox x:Name="ResultsList"
                     IsSynchronizedWithCurrentItem="False"
                     SelectionChanged="ResultsList_SelectionChanged"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Margin="10,10,0,4"
                                           Style="{StaticResource Text.Section}"
                                           Text="{Binding Name}" />
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                    </GroupStyle>
                </ListBox.GroupStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <TextBlock FontSize="13" Text="{Binding Name}" />
                            <TextBlock FontSize="11"
                                       Foreground="{StaticResource Brush.Fg2}"
                                       Text="{Binding Description}"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Border x:Name="ToolPane" Visibility="Collapsed">
                <ContentControl x:Name="ToolHost" />
            </Border>
        </Grid>
    </DockPanel>
</inf:GlassWindow>
