<UserControl x:Class="Delp.App.Tools.DataFormat.XmlFormatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="16">

        <WrapPanel DockPanel.Dock="Top">
            <Button x:Name="FormatBtn" Style="{StaticResource Button.Primary}" Content="Format"
                    Click="Format_Click" Margin="0,0,8,10" />
            <Button x:Name="MinifyBtn" Content="Minify" Click="Minify_Click" Margin="0,0,16,10" />
            <TextBlock Text="Indent" VerticalAlignment="Center" Style="{StaticResource Text.Sub}" Margin="0,0,6,10" />
            <ComboBox x:Name="IndentCombo" Width="100" SelectedIndex="0"
                      SelectionChanged="IndentCombo_SelectionChanged" Margin="0,0,16,10">
                <ComboBoxItem Content="2 spaces" Tag="2" />
                <ComboBoxItem Content="4 spaces" Tag="4" />
                <ComboBoxItem Content="Tab" Tag="tab" />
            </ComboBox>
            <CheckBox x:Name="OmitDeclarationBox" Content="Omit XML declaration"
                      Checked="Option_Changed" Unchecked="Option_Changed" Margin="0,0,16,10" />
            <TextBlock x:Name="ValidityText" VerticalAlignment="Center" Style="{StaticResource Text.Sub}" Margin="0,0,0,10" />
        </WrapPanel>

        <TextBlock x:Name="ErrorText"
                   DockPanel.Dock="Bottom"
                   Margin="0,8,0,0"
                   Style="{StaticResource Text.Error}"
                   Visibility="Collapsed" />

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Style="{StaticResource Text.Section}" Text="INPUT" Margin="0,0,0,6" />
            <Border x:Name="InputHost" Grid.Row="1" Style="{StaticResource Card.Editor}" Margin="0,0,0,14" />

            <DockPanel Grid.Row="2" Margin="0,0,0,6">
                <Button x:Name="CopyBtn" DockPanel.Dock="Right" Content="Copy" Click="Copy_Click" />
                <TextBlock VerticalAlignment="Center" Style="{StaticResource Text.Section}" Text="OUTPUT" />
            </DockPanel>
            <Border x:Name="OutputHost" Grid.Row="3" Style="{StaticResource Card.Editor}" />
        </Grid>
    </DockPanel>
</UserControl>
