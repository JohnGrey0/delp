<UserControl x:Class="Delp.App.Tools.DataFormat.YamlFormatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="16">

        <WrapPanel DockPanel.Dock="Top">
            <Button x:Name="FormatBtn"
                    Margin="0,0,8,8"
                    Style="{StaticResource Button.Primary}"
                    Content="Format"
                    Click="Format_Click" />
            <ComboBox x:Name="IndentCombo"
                      Width="110"
                      Margin="0,0,8,8"
                      SelectionChanged="Option_Changed">
                <ComboBoxItem Content="2 spaces" Tag="2" IsSelected="True" />
                <ComboBoxItem Content="4 spaces" Tag="4" />
            </ComboBox>
            <TextBlock VerticalAlignment="Center"
                       Style="{StaticResource Text.Sub}"
                       Text="Comments are not preserved." />
        </WrapPanel>

        <TextBlock x:Name="StatusText"
                   DockPanel.Dock="Bottom"
                   Margin="0,8,0,0"
                   FontSize="12"
                   Text="Empty input" />

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Margin="0,0,0,6"
                       Style="{StaticResource Text.Section}"
                       Text="INPUT" />
            <Border x:Name="InputHost"
                    Grid.Row="1"
                    Grid.Column="0"
                    Style="{StaticResource Card.Editor}" />

            <DockPanel Grid.Row="0"
                       Grid.Column="2"
                       Margin="0,0,0,6">
                <Button x:Name="CopyOutputBtn"
                        DockPanel.Dock="Right"
                        Content="Copy"
                        Click="CopyOutput_Click" />
                <TextBlock VerticalAlignment="Center"
                           Style="{StaticResource Text.Section}"
                           Text="OUTPUT" />
            </DockPanel>
            <Border x:Name="OutputHost"
                    Grid.Row="1"
                    Grid.Column="2"
                    Style="{StaticResource Card.Editor}" />
        </Grid>
    </DockPanel>
</UserControl>
