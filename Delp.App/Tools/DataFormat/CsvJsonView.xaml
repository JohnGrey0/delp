<UserControl x:Class="Delp.App.Tools.DataFormat.CsvJsonView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="16">

        <WrapPanel DockPanel.Dock="Top">
            <TextBlock Text="Delimiter" VerticalAlignment="Center" Style="{StaticResource Text.Sub}" Margin="0,0,6,10" />
            <ComboBox x:Name="DelimiterCombo" Width="90" SelectedIndex="0"
                      SelectionChanged="Option_Changed" Margin="0,0,16,10">
                <ComboBoxItem Content="Auto" Tag="" />
                <ComboBoxItem Content="," Tag="," />
                <ComboBoxItem Content=";" Tag=";" />
                <ComboBoxItem Content="Tab" Tag="&#9;" />
                <ComboBoxItem Content="|" Tag="|" />
            </ComboBox>
            <CheckBox x:Name="HeaderBox" Content="Header row" IsChecked="True"
                      Checked="Option_Changed" Unchecked="Option_Changed" Margin="0,0,16,10" />
            <CheckBox x:Name="InferTypesBox" Content="Infer types" IsChecked="True"
                      Checked="Option_Changed" Unchecked="Option_Changed" Margin="0,0,16,10" />
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" Style="{StaticResource Text.Sub}" Margin="0,0,0,10" />
        </WrapPanel>

        <TextBlock x:Name="ErrorText"
                   DockPanel.Dock="Bottom"
                   Margin="0,8,0,0"
                   Style="{StaticResource Text.Error}"
                   Visibility="Collapsed" />

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,6">
                <Button x:Name="CopyCsvBtn" DockPanel.Dock="Right" Content="Copy" Click="CopyCsv_Click" />
                <TextBlock VerticalAlignment="Center" Style="{StaticResource Text.Section}" Text="CSV" />
            </DockPanel>
            <Border x:Name="CsvHost" Grid.Row="1" Style="{StaticResource Card.Editor}" Margin="0,0,0,14" />

            <DockPanel Grid.Row="2" Margin="0,0,0,6">
                <Button x:Name="CopyJsonBtn" DockPanel.Dock="Right" Content="Copy" Click="CopyJson_Click" />
                <TextBlock VerticalAlignment="Center" Style="{StaticResource Text.Section}" Text="JSON" />
            </DockPanel>
            <Border x:Name="JsonHost" Grid.Row="3" Style="{StaticResource Card.Editor}" />
        </Grid>
    </DockPanel>
</UserControl>
