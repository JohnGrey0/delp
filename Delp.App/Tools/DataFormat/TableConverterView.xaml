<UserControl x:Class="Delp.App.Tools.DataFormat.TableConverterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="16">

        <TextBlock x:Name="ErrorText"
                   DockPanel.Dock="Bottom"
                   Margin="0,8,0,0"
                   Style="{StaticResource Text.Error}"
                   Visibility="Collapsed" />

        <WrapPanel DockPanel.Dock="Top">
            <TextBlock Text="From" VerticalAlignment="Center" Style="{StaticResource Text.Sub}" Margin="0,0,6,10" />
            <ComboBox x:Name="FromCombo" Width="104" SelectedIndex="0"
                      SelectionChanged="Combo_SelectionChanged" Margin="0,0,16,10">
                <ComboBoxItem Content="Auto-detect" />
                <ComboBoxItem Content="CSV" />
                <ComboBoxItem Content="TSV" />
                <ComboBoxItem Content="Markdown" />
                <ComboBoxItem Content="JSON" />
            </ComboBox>

            <CheckBox x:Name="HeaderBox"
                      Content="Header row"
                      IsChecked="True"
                      Checked="Option_Changed"
                      Unchecked="Option_Changed"
                      Margin="0,0,16,10" />

            <StackPanel x:Name="DelimiterRow" Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Delimiter" VerticalAlignment="Center" Style="{StaticResource Text.Sub}" Margin="0,0,6,0" />
                <TextBox x:Name="DelimiterBox" Width="40" Text="," TextChanged="TextOption_Changed" />
            </StackPanel>
        </WrapPanel>

        <TextBlock x:Name="DetectedText"
                   DockPanel.Dock="Top"
                   Style="{StaticResource Text.Sub}"
                   Margin="0,0,0,10" />

        <WrapPanel DockPanel.Dock="Top">
            <TextBlock Text="To" VerticalAlignment="Center" Style="{StaticResource Text.Sub}" Margin="0,0,6,10" />
            <ComboBox x:Name="ToCombo" Width="118" SelectedIndex="0"
                      SelectionChanged="Combo_SelectionChanged" Margin="0,0,16,10">
                <ComboBoxItem Content="Markdown" />
                <ComboBoxItem Content="ASCII Box" />
                <ComboBoxItem Content="HTML" />
                <ComboBoxItem Content="SQL INSERT" />
                <ComboBoxItem Content="JSON" />
                <ComboBoxItem Content="CSV" />
                <ComboBoxItem Content="TSV" />
                <ComboBoxItem Content="LaTeX" />
            </ComboBox>

            <StackPanel x:Name="AlignmentRow" Orientation="Horizontal" Margin="0,0,16,10">
                <TextBlock Text="Align" VerticalAlignment="Center" Style="{StaticResource Text.Sub}" Margin="0,0,6,0" />
                <ComboBox x:Name="AlignmentCombo" Width="88" SelectedIndex="0" SelectionChanged="Combo_SelectionChanged">
                    <ComboBoxItem Content="None" />
                    <ComboBoxItem Content="Left" />
                    <ComboBoxItem Content="Center" />
                    <ComboBoxItem Content="Right" />
                </ComboBox>
            </StackPanel>

            <StackPanel x:Name="BordersRow" Orientation="Horizontal" Margin="0,0,16,10">
                <TextBlock Text="Borders" VerticalAlignment="Center" Style="{StaticResource Text.Sub}" Margin="0,0,6,0" />
                <ComboBox x:Name="BordersCombo" Width="88" SelectedIndex="0" SelectionChanged="Combo_SelectionChanged">
                    <ComboBoxItem Content="ASCII" />
                    <ComboBoxItem Content="Unicode" />
                </ComboBox>
            </StackPanel>

            <StackPanel x:Name="ShapeRow" Orientation="Horizontal" Margin="0,0,16,10">
                <TextBlock Text="Shape" VerticalAlignment="Center" Style="{StaticResource Text.Sub}" Margin="0,0,6,0" />
                <ComboBox x:Name="ShapeCombo" Width="88" SelectedIndex="0" SelectionChanged="Combo_SelectionChanged">
                    <ComboBoxItem Content="Objects" />
                    <ComboBoxItem Content="Arrays" />
                </ComboBox>
            </StackPanel>

            <StackPanel x:Name="TableNameRow" Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Table" VerticalAlignment="Center" Style="{StaticResource Text.Sub}" Margin="0,0,6,0" />
                <TextBox x:Name="TableNameBox" Width="120" Text="table_name" TextChanged="TextOption_Changed" />
            </StackPanel>
        </WrapPanel>

        <TextBlock DockPanel.Dock="Top"
                   Style="{StaticResource Text.Sub}"
                   Margin="0,0,0,10"
                   Text="Tip: paste straight from Excel / Google Sheets." />

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,6">
                <Button x:Name="CopyInputBtn" DockPanel.Dock="Right" Content="Copy" Click="CopyInput_Click" />
                <TextBlock VerticalAlignment="Center" Style="{StaticResource Text.Section}" Text="INPUT" />
            </DockPanel>
            <Border x:Name="InputHost" Grid.Row="1" Style="{StaticResource Card.Editor}" Margin="0,0,0,14" />

            <DockPanel Grid.Row="2" Margin="0,0,0,6">
                <Button x:Name="CopyOutputBtn" DockPanel.Dock="Right" Content="Copy" Click="CopyOutput_Click" />
                <TextBlock VerticalAlignment="Center" Style="{StaticResource Text.Section}" Text="OUTPUT" />
            </DockPanel>
            <Border x:Name="OutputHost" Grid.Row="3" Style="{StaticResource Card.Editor}" />
        </Grid>
    </DockPanel>
</UserControl>
