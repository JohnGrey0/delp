<UserControl x:Class="Delp.App.Tools.DataFormat.JsonTypesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="16">

        <TextBlock x:Name="ErrorText"
                   DockPanel.Dock="Bottom"
                   Margin="0,8,0,0"
                   Style="{StaticResource Text.Error}"
                   Visibility="Collapsed" />

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="Root name" VerticalAlignment="Center" Margin="0,0,8,0" Style="{StaticResource Text.Sub}" />
            <TextBox x:Name="RootNameBox" Width="140" Text="Root" TextChanged="Input_Changed" />
        </StackPanel>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Style="{StaticResource Text.Section}" Text="INPUT JSON" Margin="0,0,0,6" />
                <Border x:Name="InputHost" Grid.Row="1" Style="{StaticResource Card.Editor}" />
            </Grid>

            <TabControl x:Name="OutputTabs" Grid.Column="2">
                <TabItem Header="C#">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <WrapPanel Grid.Row="0" Margin="0,0,0,8">
                            <CheckBox x:Name="RecordsBox" Content="Records" IsChecked="True" Margin="0,0,14,4"
                                      Checked="Option_Changed" Unchecked="Option_Changed" />
                            <CheckBox x:Name="JsonPropertyNamesBox" Content="JsonPropertyName attrs" IsChecked="True" Margin="0,0,14,4"
                                      Checked="Option_Changed" Unchecked="Option_Changed" />
                        </WrapPanel>
                        <DockPanel Grid.Row="1" Margin="0,0,0,6">
                            <Button x:Name="CopyCsBtn" DockPanel.Dock="Right" Content="Copy" Click="CopyCs_Click" />
                            <TextBlock VerticalAlignment="Center" Style="{StaticResource Text.Section}" Text="C#" />
                        </DockPanel>
                        <Border x:Name="CsHost" Grid.Row="2" Style="{StaticResource Card.Editor}" />
                    </Grid>
                </TabItem>
                <TabItem Header="TYPESCRIPT">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <WrapPanel Grid.Row="0" Margin="0,0,0,8">
                            <CheckBox x:Name="InterfacesBox" Content="Interfaces (vs type aliases)" IsChecked="True" Margin="0,0,14,4"
                                      Checked="Option_Changed" Unchecked="Option_Changed" />
                        </WrapPanel>
                        <DockPanel Grid.Row="1" Margin="0,0,0,6">
                            <Button x:Name="CopyTsBtn" DockPanel.Dock="Right" Content="Copy" Click="CopyTs_Click" />
                            <TextBlock VerticalAlignment="Center" Style="{StaticResource Text.Section}" Text="TYPESCRIPT" />
                        </DockPanel>
                        <Border x:Name="TsHost" Grid.Row="2" Style="{StaticResource Card.Editor}" />
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </DockPanel>
</UserControl>
