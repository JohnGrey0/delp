<UserControl x:Class="Delp.App.Tools.DataFormat.DataConverterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="16">

        <TextBlock x:Name="ErrorText"
                   DockPanel.Dock="Bottom"
                   Margin="0,8,0,0"
                   Style="{StaticResource Text.Error}"
                   Visibility="Collapsed" />

        <WrapPanel DockPanel.Dock="Top">
            <TextBlock Text="From" VerticalAlignment="Center" Style="{StaticResource Text.Sub}" Margin="0,0,6,10" />
            <ComboBox x:Name="FromCombo" Width="88" SelectedIndex="0"
                      SelectionChanged="FromCombo_SelectionChanged" Margin="0,0,8,10">
                <ComboBoxItem Content="JSON" />
                <ComboBoxItem Content="YAML" />
                <ComboBoxItem Content="XML" />
                <ComboBoxItem Content="CSV" />
                <ComboBoxItem Content="TOML" />
            </ComboBox>
            <Button x:Name="SwapBtn"
                    Style="{StaticResource Button.Icon}"
                    Content="&#8646;"
                    ToolTip="Swap FROM and TO"
                    Click="Swap_Click"
                    Margin="0,0,8,10" />
            <TextBlock Text="To" VerticalAlignment="Center" Style="{StaticResource Text.Sub}" Margin="0,0,6,10" />
            <ComboBox x:Name="ToCombo" Width="88" SelectedIndex="1"
                      SelectionChanged="ToCombo_SelectionChanged" Margin="0,0,0,10">
                <ComboBoxItem Content="JSON" />
                <ComboBoxItem Content="YAML" />
                <ComboBoxItem Content="XML" />
                <ComboBoxItem Content="CSV" />
                <ComboBoxItem Content="TOML" />
            </ComboBox>
        </WrapPanel>

        <TextBlock x:Name="SnapNoteText"
                   DockPanel.Dock="Top"
                   Style="{StaticResource Text.Sub}"
                   Margin="0,0,0,10"
                   TextWrapping="Wrap"
                   Visibility="Collapsed" />

        <WrapPanel x:Name="RootNameRow" DockPanel.Dock="Top" Visibility="Collapsed">
            <TextBlock Text="Root name (JSON → XML)" VerticalAlignment="Center" Style="{StaticResource Text.Sub}" Margin="0,0,8,10" />
            <TextBox x:Name="RootNameBox" Width="140" Text="root" TextChanged="RootName_TextChanged" Margin="0,0,0,10" />
        </WrapPanel>

        <WrapPanel x:Name="CsvOptionsRow" DockPanel.Dock="Top" Visibility="Collapsed">
            <TextBlock Text="Delimiter" VerticalAlignment="Center" Style="{StaticResource Text.Sub}" Margin="0,0,6,10" />
            <ComboBox x:Name="DelimiterCombo" Width="90" SelectedIndex="0"
                      SelectionChanged="Option_Changed" Margin="0,0,16,10">
                <ComboBoxItem Content="Auto" Tag="" />
                <ComboBoxItem Content="," Tag="," />
                <ComboBoxItem Content=";" Tag=";" />
                <ComboBoxItem Content="Tab" Tag="&#9;" />
                <ComboBoxItem Content="|" Tag="|" />
            </ComboBox>
            <CheckBox x:Name="HeaderBox" Content="Header row" IsChecked="True"
                      Checked="Option_Changed" Unchecked="Option_Changed" Margin="0,0,16,10" />
            <CheckBox x:Name="InferTypesBox" Content="Infer types" IsChecked="True"
                      Checked="Option_Changed" Unchecked="Option_Changed" Margin="0,0,16,10" />
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" Style="{StaticResource Text.Sub}" Margin="0,0,0,10" />
        </WrapPanel>

        <TextBlock x:Name="TomlNote"
                   DockPanel.Dock="Top"
                   Style="{StaticResource Text.Sub}"
                   Margin="0,0,0,10"
                   TextWrapping="Wrap"
                   Visibility="Collapsed"
                   Text="TOML has no null — remove null values before converting to TOML." />

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,6">
                <Button x:Name="CopyTopBtn" DockPanel.Dock="Right" Content="Copy" Click="CopyTop_Click" />
                <TextBlock x:Name="TopLabel" VerticalAlignment="Center" Style="{StaticResource Text.Section}" Text="JSON" />
            </DockPanel>
            <Border x:Name="TopHost" Grid.Row="1" Style="{StaticResource Card.Editor}" Margin="0,0,0,14" />

            <DockPanel Grid.Row="2" Margin="0,0,0,6">
                <Button x:Name="CopyBottomBtn" DockPanel.Dock="Right" Content="Copy" Click="CopyBottom_Click" />
                <TextBlock x:Name="BottomLabel" VerticalAlignment="Center" Style="{StaticResource Text.Section}" Text="YAML" />
            </DockPanel>
            <Border x:Name="BottomHost" Grid.Row="3" Style="{StaticResource Card.Editor}" />
        </Grid>
    </DockPanel>
</UserControl>
