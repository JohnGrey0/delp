<UserControl x:Class="Delp.App.Tools.DataFormat.JsonPathView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="16">
        <TabControl x:Name="MainTabs">
            <TabItem Header="JSONPATH">
                <DockPanel Margin="0,10,0,0">

                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                        <TextBox x:Name="PathBox"
                                 FontFamily="{StaticResource Font.Mono}"
                                 Text="$"
                                 TextChanged="PathBox_TextChanged" />
                        <TextBlock Margin="0,6,0,0"
                                   Style="{StaticResource Text.Sub}"
                                   Text="$.store.book[0].title  ·  $..price  ·  $.items[?(@.price &gt; 10)]" />
                    </StackPanel>

                    <TextBlock x:Name="StatusText"
                               DockPanel.Dock="Bottom"
                               Margin="0,8,0,0"
                               FontSize="12"
                               Text="Empty input" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Margin="0,0,0,6"
                                   Style="{StaticResource Text.Section}"
                                   Text="INPUT" />
                        <Border x:Name="InputHost"
                                Grid.Row="1"
                                Grid.Column="0"
                                Style="{StaticResource Card.Editor}" />

                        <DockPanel Grid.Row="0"
                                   Grid.Column="2"
                                   Margin="0,0,0,6">
                            <Button x:Name="CopyResultsBtn"
                                    DockPanel.Dock="Right"
                                    Content="Copy"
                                    Click="CopyResults_Click" />
                            <TextBlock VerticalAlignment="Center"
                                       Style="{StaticResource Text.Section}"
                                       Text="RESULTS" />
                        </DockPanel>
                        <Border x:Name="ResultsHost"
                                Grid.Row="1"
                                Grid.Column="2"
                                Style="{StaticResource Card.Editor}" />
                    </Grid>
                </DockPanel>
            </TabItem>

            <TabItem Header="XPATH">
                <DockPanel Margin="0,10,0,0">

                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                        <TextBox x:Name="XPathExprBox"
                                 FontFamily="{StaticResource Font.Mono}"
                                 TextChanged="XPathExprBox_TextChanged" />
                        <TextBlock Margin="0,6,0,0"
                                   Style="{StaticResource Text.Sub}"
                                   TextWrapping="Wrap"
                                   Text="//book/title  ·  //book/@id  ·  count(//book)  ·  Namespaces: match by local-name() — e.g. //*[local-name()='item']" />
                    </StackPanel>

                    <TextBlock x:Name="XPathStatusText"
                               DockPanel.Dock="Bottom"
                               Margin="0,8,0,0"
                               FontSize="12"
                               Text="Empty input" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Margin="0,0,0,6"
                                   Style="{StaticResource Text.Section}"
                                   Text="INPUT (XML)" />
                        <Border x:Name="XPathInputHost"
                                Grid.Row="1"
                                Grid.Column="0"
                                Style="{StaticResource Card.Editor}" />

                        <DockPanel Grid.Row="0"
                                   Grid.Column="2"
                                   Margin="0,0,0,6">
                            <Button x:Name="CopyXPathResultsBtn"
                                    DockPanel.Dock="Right"
                                    Content="Copy"
                                    Click="CopyXPathResults_Click" />
                            <TextBlock VerticalAlignment="Center"
                                       Style="{StaticResource Text.Section}"
                                       Text="RESULTS" />
                        </DockPanel>

                        <!-- No outer ScrollViewer around this ListBox — the app's smoke lint flags
                             that as a mouse-wheel trap; ScrollViewer.VerticalScrollBarVisibility
                             below is an attached property that just enables the ListBox's own
                             built-in (virtualized) scrolling. -->
                        <ListBox x:Name="XPathResultsList"
                                 Grid.Row="1"
                                 Grid.Column="2"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,4,0,6">
                                        <TextBlock FontFamily="{StaticResource Font.Mono}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource Brush.Fg2}"
                                                   Text="{Binding Path}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock FontFamily="{StaticResource Font.Mono}"
                                                   FontSize="12"
                                                   Text="{Binding Snippet}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </DockPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</UserControl>
