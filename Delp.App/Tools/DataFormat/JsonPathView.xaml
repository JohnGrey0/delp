<UserControl x:Class="Delp.App.Tools.DataFormat.JsonPathView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="16">

        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBox x:Name="PathBox"
                     FontFamily="{StaticResource Font.Mono}"
                     Text="$"
                     TextChanged="PathBox_TextChanged" />
            <TextBlock Margin="0,6,0,0"
                       Style="{StaticResource Text.Sub}"
                       Text="$.store.book[0].title  ·  $..price  ·  $.items[?(@.price &gt; 10)]" />
        </StackPanel>

        <TextBlock x:Name="StatusText"
                   DockPanel.Dock="Bottom"
                   Margin="0,8,0,0"
                   FontSize="12"
                   Text="Empty input" />

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Margin="0,0,0,6"
                       Style="{StaticResource Text.Section}"
                       Text="INPUT" />
            <Border x:Name="InputHost"
                    Grid.Row="1"
                    Grid.Column="0"
                    Style="{StaticResource Card.Editor}" />

            <DockPanel Grid.Row="0"
                       Grid.Column="2"
                       Margin="0,0,0,6">
                <Button x:Name="CopyResultsBtn"
                        DockPanel.Dock="Right"
                        Content="Copy"
                        Click="CopyResults_Click" />
                <TextBlock VerticalAlignment="Center"
                           Style="{StaticResource Text.Section}"
                           Text="RESULTS" />
            </DockPanel>
            <Border x:Name="ResultsHost"
                    Grid.Row="1"
                    Grid.Column="2"
                    Style="{StaticResource Card.Editor}" />
        </Grid>
    </DockPanel>
</UserControl>
