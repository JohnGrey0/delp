<UserControl x:Class="Delp.App.Tools.DataFormat.FormatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="16">

        <WrapPanel DockPanel.Dock="Top">
            <TextBlock Text="Language"
                       VerticalAlignment="Center"
                       Style="{StaticResource Text.Sub}"
                       Margin="0,0,6,10" />
            <ComboBox x:Name="LanguageCombo"
                      Width="110"
                      Margin="0,0,16,10"
                      SelectionChanged="LanguageCombo_SelectionChanged">
                <ComboBoxItem Content="JSON" IsSelected="True" />
                <ComboBoxItem Content="YAML" />
                <ComboBoxItem Content="XML" />
                <ComboBoxItem Content="SQL" />
                <ComboBoxItem Content="GraphQL" />
            </ComboBox>

            <Button x:Name="FormatBtn"
                    Style="{StaticResource Button.Primary}"
                    Content="Format"
                    Click="Format_Click"
                    Margin="0,0,8,10" />
            <Button x:Name="MinifyBtn"
                    Content="Minify"
                    Click="Minify_Click"
                    Margin="0,0,16,10" />

            <TextBlock x:Name="IndentLabel"
                       Text="Indent"
                       VerticalAlignment="Center"
                       Style="{StaticResource Text.Sub}"
                       Margin="0,0,6,10" />
            <ComboBox x:Name="IndentCombo"
                      Width="110"
                      Margin="0,0,16,10"
                      SelectionChanged="Option_Changed">
                <ComboBoxItem x:Name="Indent2Item" Content="2 spaces" Tag="2" IsSelected="True" />
                <ComboBoxItem x:Name="Indent4Item" Content="4 spaces" Tag="4" />
                <ComboBoxItem x:Name="IndentTabItem" Content="Tab" Tag="Tab" />
            </ComboBox>

            <CheckBox x:Name="SortKeysBox"
                      Content="Sort keys"
                      Margin="0,0,16,10"
                      Checked="Option_Changed"
                      Unchecked="Option_Changed" />
            <CheckBox x:Name="EscapeNonAsciiBox"
                      Content="Escape non-ASCII"
                      Margin="0,0,16,10"
                      Checked="Option_Changed"
                      Unchecked="Option_Changed" />
            <CheckBox x:Name="OmitDeclarationBox"
                      Content="Omit XML declaration"
                      Margin="0,0,16,10"
                      Checked="Option_Changed"
                      Unchecked="Option_Changed" />
            <CheckBox x:Name="UppercaseBox"
                      Content="Uppercase keywords"
                      IsChecked="True"
                      Margin="0,0,16,10"
                      Checked="Option_Changed"
                      Unchecked="Option_Changed" />
            <TextBlock x:Name="YamlNoteText"
                       VerticalAlignment="Center"
                       Style="{StaticResource Text.Sub}"
                       Text="Comments are not preserved."
                       Margin="0,0,0,10" />
        </WrapPanel>

        <TextBlock x:Name="StatusText"
                   DockPanel.Dock="Bottom"
                   Margin="0,8,0,0"
                   FontSize="12"
                   Text="Empty input" />

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Margin="0,0,0,6"
                       Style="{StaticResource Text.Section}"
                       Text="INPUT" />
            <Border x:Name="InputHost"
                    Grid.Row="1"
                    Grid.Column="0"
                    Style="{StaticResource Card.Editor}" />

            <DockPanel Grid.Row="0"
                       Grid.Column="2"
                       Margin="0,0,0,6">
                <Button x:Name="CopyOutputBtn"
                        DockPanel.Dock="Right"
                        Content="Copy"
                        Click="CopyOutput_Click" />
                <TextBlock VerticalAlignment="Center"
                           Style="{StaticResource Text.Section}"
                           Text="OUTPUT" />
            </DockPanel>
            <Border x:Name="OutputHost"
                    Grid.Row="1"
                    Grid.Column="2"
                    Style="{StaticResource Card.Editor}" />
        </Grid>
    </DockPanel>
</UserControl>
