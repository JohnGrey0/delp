<UserControl x:Class="Delp.App.Tools.Hashing.UuidV3View"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="View_Loaded">
    <DockPanel Margin="16">

        <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,6">
            <StackPanel Orientation="Horizontal" Margin="0,0,16,10">
                <TextBlock Text="Namespace" VerticalAlignment="Center" Margin="0,0,8,0" Style="{StaticResource Text.Sub}" />
                <ComboBox x:Name="NamespaceCombo" Width="120" SelectedIndex="0" SelectionChanged="Option_Changed">
                    <ComboBoxItem Content="DNS" />
                    <ComboBoxItem Content="URL" />
                    <ComboBoxItem Content="OID" />
                    <ComboBoxItem Content="X.500" />
                    <ComboBoxItem Content="Custom" />
                </ComboBox>
            </StackPanel>
            <StackPanel x:Name="CustomNsPanel" Orientation="Horizontal" Margin="0,0,16,10" Visibility="Collapsed">
                <TextBlock Text="Custom namespace UUID" VerticalAlignment="Center" Margin="0,0,8,0" Style="{StaticResource Text.Sub}" />
                <TextBox x:Name="CustomNsBox" Width="230" TextChanged="Option_Changed" />
            </StackPanel>
            <CheckBox x:Name="UppercaseBox" Content="Uppercase" Margin="0,0,16,10" Checked="Option_Changed" Unchecked="Option_Changed" />
            <CheckBox x:Name="BracesBox" Content="Braces" Margin="0,0,16,10" Checked="Option_Changed" Unchecked="Option_Changed" />
            <CheckBox x:Name="NoHyphensBox" Content="No hyphens" Margin="0,0,16,10" Checked="Option_Changed" Unchecked="Option_Changed" />
        </WrapPanel>

        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" Margin="0,0,8,0" Style="{StaticResource Text.Section}" Text="NAME" />
            <TextBox x:Name="NameBox" Text="www.example.com" TextChanged="Option_Changed" />
        </DockPanel>

        <TextBlock x:Name="ErrorText"
                   DockPanel.Dock="Bottom"
                   Margin="0,8,0,0"
                   Style="{StaticResource Text.Error}"
                   Visibility="Collapsed" />

        <DockPanel>
            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="CopyJsonBtn" Content="Copy as JSON array" Click="CopyJson_Click" Margin="0,0,8,0" />
                    <Button x:Name="CopyBtn" Content="Copy" Click="Copy_Click" />
                </StackPanel>
                <TextBlock VerticalAlignment="Center" Style="{StaticResource Text.Section}" Text="OUTPUT" />
            </DockPanel>
            <TextBox x:Name="OutputBox"
                     Style="{StaticResource TextBox.Mono}"
                     IsReadOnly="True" />
        </DockPanel>
    </DockPanel>
</UserControl>
