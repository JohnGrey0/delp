<UserControl x:Class="Delp.App.Tools.Hashing.FileChecksumView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="16">

        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <Border x:Name="DropZone"
                    Style="{StaticResource Card}"
                    Padding="16"
                    AllowDrop="True"
                    PreviewDragOver="DropZone_PreviewDragOver"
                    Drop="DropZone_Drop">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock x:Name="DropHint"
                               Style="{StaticResource Text.Sub}"
                               HorizontalAlignment="Center"
                               Text="Drop a file here or browse…" />
                    <Button x:Name="BrowseBtn"
                            Content="Browse…"
                            HorizontalAlignment="Center"
                            Margin="0,10,0,0"
                            Click="Browse_Click" />
                    <TextBlock x:Name="FileInfoText"
                               Style="{StaticResource Text.Mono}"
                               HorizontalAlignment="Center"
                               Margin="0,10,0,0"
                               Visibility="Collapsed" />
                </StackPanel>
            </Border>

            <WrapPanel Margin="0,12,0,0">
                <TextBlock VerticalAlignment="Center" Style="{StaticResource Text.Section}" Text="ALGORITHM" Margin="0,0,8,6" />
                <ComboBox x:Name="AlgoCombo" Width="120" Margin="0,0,0,6" SelectionChanged="AlgoCombo_SelectionChanged">
                    <ComboBoxItem Content="MD5" />
                    <ComboBoxItem Content="SHA-1" />
                    <ComboBoxItem Content="SHA-256" IsSelected="True" />
                    <ComboBoxItem Content="SHA-384" />
                    <ComboBoxItem Content="SHA-512" />
                </ComboBox>
            </WrapPanel>
        </StackPanel>

        <TextBlock x:Name="ErrorText"
                   DockPanel.Dock="Bottom"
                   Margin="0,8,0,0"
                   Style="{StaticResource Text.Error}"
                   Visibility="Collapsed" />

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <DockPanel Margin="0,0,0,6">
                    <Button x:Name="CopyHashBtn" DockPanel.Dock="Right" Content="Copy" Click="CopyHash_Click" />
                    <TextBlock VerticalAlignment="Center" Style="{StaticResource Text.Section}" Text="COMPUTED HASH" />
                </DockPanel>
                <TextBox x:Name="HashBox"
                         Style="{StaticResource TextBox.Mono}"
                         IsReadOnly="True"
                         Height="56"
                         Margin="0,0,0,14" />

                <TextBlock Style="{StaticResource Text.Section}" Text="EXPECTED HASH" Margin="0,0,0,6" />
                <TextBox x:Name="ExpectedBox"
                         Style="{StaticResource TextBox.Mono}"
                         Height="56"
                         TextChanged="ExpectedBox_TextChanged" />

                <TextBlock x:Name="MatchOkText"
                           Margin="0,8,0,0"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource Brush.Success}"
                           Text="✓ Match"
                           Visibility="Collapsed" />
                <TextBlock x:Name="MatchFailText"
                           Margin="0,8,0,0"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource Brush.Danger}"
                           Text="✗ No match"
                           Visibility="Collapsed" />
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
