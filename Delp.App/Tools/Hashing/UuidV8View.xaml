<UserControl x:Class="Delp.App.Tools.Hashing.UuidV8View"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="16">

        <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,6">
            <StackPanel Orientation="Horizontal" Margin="0,0,16,10">
                <TextBlock Text="Custom data (hex, up to 32 digits)" VerticalAlignment="Center" Margin="0,0,8,0" Style="{StaticResource Text.Sub}" />
                <TextBox x:Name="CustomHexBox" Width="230" />
            </StackPanel>
            <CheckBox x:Name="RandomFillBox" Content="Random fill" IsChecked="True" Margin="0,0,16,10" />
            <StackPanel Orientation="Horizontal" Margin="0,0,16,10">
                <TextBlock Text="Count" VerticalAlignment="Center" Margin="0,0,8,0" Style="{StaticResource Text.Sub}" />
                <TextBox x:Name="CountBox" Width="70" Text="1" />
            </StackPanel>
            <CheckBox x:Name="UppercaseBox" Content="Uppercase" Margin="0,0,16,10" Checked="Option_Changed" Unchecked="Option_Changed" />
            <CheckBox x:Name="BracesBox" Content="Braces" Margin="0,0,16,10" Checked="Option_Changed" Unchecked="Option_Changed" />
            <CheckBox x:Name="NoHyphensBox" Content="No hyphens" Margin="0,0,16,10" Checked="Option_Changed" Unchecked="Option_Changed" />
            <Button x:Name="GenerateBtn" Content="Generate" Style="{StaticResource Button.Primary}" Click="Generate_Click" Margin="0,0,0,10" />
        </WrapPanel>

        <TextBlock DockPanel.Dock="Top"
                   Margin="0,0,0,10"
                   Style="{StaticResource Text.Sub}"
                   Text="128 bits total: the version nibble (4 bits, forced to 8) and variant (2 bits, forced to 10) are fixed; the remaining 122 bits carry your custom data, zero-padded on the right, or random fill when the field is empty." />

        <TextBlock x:Name="ErrorText"
                   DockPanel.Dock="Bottom"
                   Margin="0,8,0,0"
                   Style="{StaticResource Text.Error}"
                   Visibility="Collapsed" />

        <DockPanel>
            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="CopyJsonBtn" Content="Copy as JSON array" Click="CopyJson_Click" Margin="0,0,8,0" />
                    <Button x:Name="CopyBtn" Content="Copy" Click="Copy_Click" />
                </StackPanel>
                <TextBlock VerticalAlignment="Center" Style="{StaticResource Text.Section}" Text="OUTPUT" />
            </DockPanel>
            <TextBox x:Name="OutputBox"
                     Style="{StaticResource TextBox.Mono}"
                     IsReadOnly="True" />
        </DockPanel>
    </DockPanel>
</UserControl>
