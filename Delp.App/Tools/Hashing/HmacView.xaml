<UserControl x:Class="Delp.App.Tools.Hashing.HmacView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="16">

        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <WrapPanel>
                <TextBlock VerticalAlignment="Center" Style="{StaticResource Text.Section}" Text="KEY" Margin="0,0,8,6" />
                <TextBox x:Name="KeyBox"
                         Width="200"
                         Style="{StaticResource TextBox.Mono}"
                         AcceptsReturn="False"
                         TextWrapping="NoWrap"
                         VerticalContentAlignment="Center"
                         Margin="0,0,8,6"
                         TextChanged="KeyBox_TextChanged" />
                <ComboBox x:Name="KeyFormatCombo" Width="100" Margin="0,0,16,6" SelectionChanged="Combo_SelectionChanged">
                    <ComboBoxItem Content="UTF-8" IsSelected="True" />
                    <ComboBoxItem Content="Hex" />
                    <ComboBoxItem Content="Base64" />
                </ComboBox>
                <TextBlock VerticalAlignment="Center" Style="{StaticResource Text.Section}" Text="ALGORITHM" Margin="0,0,8,6" />
                <ComboBox x:Name="AlgoCombo" Width="100" Margin="0,0,0,6" SelectionChanged="Combo_SelectionChanged">
                    <ComboBoxItem Content="MD5" />
                    <ComboBoxItem Content="SHA-1" />
                    <ComboBoxItem Content="SHA-256" IsSelected="True" />
                    <ComboBoxItem Content="SHA-384" />
                    <ComboBoxItem Content="SHA-512" />
                </ComboBox>
            </WrapPanel>
            <TextBlock x:Name="EmptyKeyNote"
                       Style="{StaticResource Text.Sub}"
                       Foreground="{StaticResource Brush.Warning}"
                       Text="Empty key — HMAC will still compute, but an empty key provides no real security."
                       Visibility="Collapsed"
                       Margin="0,4,0,0" />
        </StackPanel>

        <TextBlock x:Name="ErrorText"
                   DockPanel.Dock="Bottom"
                   Margin="0,8,0,0"
                   Style="{StaticResource Text.Error}"
                   Visibility="Collapsed" />

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Style="{StaticResource Text.Section}" Text="MESSAGE" Margin="0,0,0,6" />
            <TextBox x:Name="MessageBox"
                     Grid.Row="1"
                     Style="{StaticResource TextBox.Mono}"
                     TextChanged="MessageBox_TextChanged" />

            <DockPanel Grid.Row="2" Margin="0,14,0,6">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <RadioButton x:Name="HexRadio"
                                 Content="Hex"
                                 GroupName="HmacOutFormat"
                                 IsChecked="True"
                                 Margin="0,0,10,0"
                                 Checked="OutputFormat_Changed" />
                    <RadioButton x:Name="Base64Radio"
                                 Content="Base64"
                                 GroupName="HmacOutFormat"
                                 Margin="0,0,10,0"
                                 Checked="OutputFormat_Changed" />
                    <Button x:Name="CopyOutputBtn" Content="Copy" Click="CopyOutput_Click" />
                </StackPanel>
                <TextBlock VerticalAlignment="Center" Style="{StaticResource Text.Section}" Text="OUTPUT" />
            </DockPanel>
            <TextBox x:Name="OutputBox"
                     Grid.Row="3"
                     Style="{StaticResource TextBox.Mono}"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     Height="70" />
        </Grid>
    </DockPanel>
</UserControl>
