<UserControl x:Class="Delp.App.Tools.Hashing.UuidView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="View_Loaded">
    <DockPanel Margin="16">

        <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,6">
            <StackPanel Orientation="Horizontal" Margin="0,0,16,10">
                <TextBlock Text="Version" VerticalAlignment="Center" Margin="0,0,8,0" Style="{StaticResource Text.Sub}" />
                <ComboBox x:Name="VersionCombo" Width="190" SelectedIndex="3" SelectionChanged="Version_Changed">
                    <ComboBoxItem Content="v1 — Time-based" />
                    <ComboBoxItem Content="v2 — DCE Security" />
                    <ComboBoxItem Content="v3 — MD5 Name-based" />
                    <ComboBoxItem Content="v4 — Random" />
                    <ComboBoxItem Content="v5 — SHA-1 Name-based" />
                    <ComboBoxItem Content="v6 — Sortable time" />
                    <ComboBoxItem Content="v7 — Unix epoch" />
                    <ComboBoxItem Content="v8 — Custom" />
                </ComboBox>
            </StackPanel>

            <StackPanel x:Name="CountPanel" Orientation="Horizontal" Margin="0,0,16,10">
                <TextBlock Text="Count" VerticalAlignment="Center" Margin="0,0,8,0" Style="{StaticResource Text.Sub}" />
                <TextBox x:Name="CountBox" Width="70" Text="1" />
            </StackPanel>

            <StackPanel x:Name="DomainPanel" Orientation="Horizontal" Margin="0,0,16,10" Visibility="Collapsed">
                <TextBlock Text="Domain" VerticalAlignment="Center" Margin="0,0,8,0" Style="{StaticResource Text.Sub}" />
                <ComboBox x:Name="DomainCombo" Width="110" SelectedIndex="0">
                    <ComboBoxItem Content="Person" />
                    <ComboBoxItem Content="Group" />
                    <ComboBoxItem Content="Org" />
                </ComboBox>
            </StackPanel>

            <StackPanel x:Name="LocalIdPanel" Orientation="Horizontal" Margin="0,0,16,10" Visibility="Collapsed">
                <TextBlock Text="Local ID" VerticalAlignment="Center" Margin="0,0,8,0" Style="{StaticResource Text.Sub}" />
                <TextBox x:Name="LocalIdBox" Width="110" Text="1000" />
            </StackPanel>

            <StackPanel x:Name="NamespacePanel" Orientation="Horizontal" Margin="0,0,16,10" Visibility="Collapsed">
                <TextBlock Text="Namespace" VerticalAlignment="Center" Margin="0,0,8,0" Style="{StaticResource Text.Sub}" />
                <ComboBox x:Name="NamespaceCombo" Width="120" SelectedIndex="0" SelectionChanged="NameBased_Changed">
                    <ComboBoxItem Content="DNS" />
                    <ComboBoxItem Content="URL" />
                    <ComboBoxItem Content="OID" />
                    <ComboBoxItem Content="X.500" />
                    <ComboBoxItem Content="Custom" />
                </ComboBox>
            </StackPanel>

            <StackPanel x:Name="CustomNsPanel" Orientation="Horizontal" Margin="0,0,16,10" Visibility="Collapsed">
                <TextBlock Text="Custom namespace UUID" VerticalAlignment="Center" Margin="0,0,8,0" Style="{StaticResource Text.Sub}" />
                <TextBox x:Name="CustomNsBox" Width="230" TextChanged="NameBased_Changed" />
            </StackPanel>

            <StackPanel x:Name="CustomHexPanel" Orientation="Horizontal" Margin="0,0,16,10" Visibility="Collapsed">
                <TextBlock Text="Custom data (hex, up to 32 digits)" VerticalAlignment="Center" Margin="0,0,8,0" Style="{StaticResource Text.Sub}" />
                <TextBox x:Name="CustomHexBox" Width="230" />
            </StackPanel>

            <CheckBox x:Name="RandomFillBox" Content="Random fill" IsChecked="True" Margin="0,0,16,10" Visibility="Collapsed" />

            <CheckBox x:Name="UppercaseBox" Content="Uppercase" Margin="0,0,16,10" Checked="FormatOption_Changed" Unchecked="FormatOption_Changed" />
            <CheckBox x:Name="BracesBox" Content="Braces" Margin="0,0,16,10" Checked="FormatOption_Changed" Unchecked="FormatOption_Changed" />
            <CheckBox x:Name="NoHyphensBox" Content="No hyphens" Margin="0,0,16,10" Checked="FormatOption_Changed" Unchecked="FormatOption_Changed" />
            <CheckBox x:Name="UseMacBox" Content="Use real MAC address" Margin="0,0,16,10" Visibility="Collapsed" />

            <Button x:Name="GenerateBtn" Content="Generate" Style="{StaticResource Button.Primary}" Click="Generate_Click" Margin="0,0,0,10" />
        </WrapPanel>

        <DockPanel x:Name="NameRow" DockPanel.Dock="Top" Margin="0,0,0,10" Visibility="Collapsed">
            <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" Margin="0,0,8,0" Style="{StaticResource Text.Section}" Text="NAME" />
            <TextBox x:Name="NameBox" Text="www.example.com" TextChanged="NameBased_Changed" />
        </DockPanel>

        <TextBlock x:Name="VersionDescription"
                   DockPanel.Dock="Top"
                   Margin="0,0,0,10"
                   Style="{StaticResource Text.Sub}" />

        <TextBlock x:Name="V2Note"
                   DockPanel.Dock="Top"
                   Margin="0,0,0,10"
                   Style="{StaticResource Text.Sub}"
                   Visibility="Collapsed"
                   Text="Rarely implemented elsewhere — Delp generates the full RFC 9562 layout. v2 embeds the local ID and domain over most of the timestamp, so batch entries differ only by node and clock sequence (randomized per UUID here)." />

        <TextBlock x:Name="V8Note"
                   DockPanel.Dock="Top"
                   Margin="0,0,0,10"
                   Style="{StaticResource Text.Sub}"
                   Visibility="Collapsed"
                   Text="128 bits total: the version nibble (4 bits, forced to 8) and variant (2 bits, forced to 10) are fixed; the remaining 122 bits carry your custom data, zero-padded on the right, or random fill when the field is empty." />

        <TextBlock x:Name="TimestampNote"
                   DockPanel.Dock="Top"
                   Margin="0,0,0,10"
                   Style="{StaticResource Text.Sub}"
                   Visibility="Collapsed" />

        <TextBlock x:Name="ErrorText"
                   DockPanel.Dock="Bottom"
                   Margin="0,8,0,0"
                   Style="{StaticResource Text.Error}"
                   Visibility="Collapsed" />

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,6">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="CopyJsonBtn" Content="Copy as JSON array" Click="CopyJson_Click" Margin="0,0,8,0" />
                    <Button x:Name="CopyBtn" Content="Copy" Click="Copy_Click" />
                </StackPanel>
                <TextBlock VerticalAlignment="Center" Style="{StaticResource Text.Section}" Text="OUTPUT" />
            </DockPanel>
            <TextBox x:Name="OutputBox"
                     Grid.Row="1"
                     Style="{StaticResource TextBox.Mono}"
                     IsReadOnly="True"
                     MinHeight="80" />

            <Border x:Name="DecodeCard" Grid.Row="2" Style="{StaticResource Card}" Margin="0,14,0,0" Padding="12" Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Style="{StaticResource Text.Section}" Text="DECODE (v7)" Margin="0,0,0,8" />
                    <TextBox x:Name="DecodeBox" TextChanged="DecodeBox_TextChanged" />
                    <TextBlock x:Name="DecodeResult" Style="{StaticResource Text.Sub}" Margin="0,10,0,0" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
