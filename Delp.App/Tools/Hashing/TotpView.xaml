<UserControl x:Class="Delp.App.Tools.Hashing.TotpView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             IsVisibleChanged="TotpView_IsVisibleChanged">
    <DockPanel Margin="16">

        <TextBlock x:Name="ErrorText"
                   DockPanel.Dock="Bottom"
                   Margin="0,8,0,0"
                   Style="{StaticResource Text.Error}"
                   Visibility="Collapsed" />

        <StackPanel DockPanel.Dock="Top">
            <TextBlock Style="{StaticResource Text.Section}" Text="SECRET (BASE32 OR otpauth:// URI)" Margin="0,0,0,4" />
            <TextBox x:Name="SecretBox"
                     Style="{StaticResource TextBox.Mono}"
                     AcceptsReturn="False"
                     TextWrapping="Wrap"
                     TextChanged="Secret_Changed" />
            <TextBlock Style="{StaticResource Text.Sub}"
                       Margin="0,4,0,0"
                       Text="Paste a Base32 secret, or a full otpauth://totp/... URI (options below are then read from the URI)." />

            <WrapPanel Margin="0,10,0,0">
                <StackPanel Margin="0,0,16,8">
                    <TextBlock Style="{StaticResource Text.Section}" Text="DIGITS" Margin="0,0,0,4" />
                    <ComboBox x:Name="DigitsBox" MinWidth="70" SelectionChanged="Option_Changed">
                        <ComboBoxItem Content="6" Tag="6" />
                        <ComboBoxItem Content="7" Tag="7" />
                        <ComboBoxItem Content="8" Tag="8" />
                    </ComboBox>
                </StackPanel>
                <StackPanel Margin="0,0,16,8">
                    <TextBlock Style="{StaticResource Text.Section}" Text="PERIOD (s)" Margin="0,0,0,4" />
                    <TextBox x:Name="PeriodBox" Width="70" TextChanged="Option_Changed" />
                </StackPanel>
                <StackPanel Margin="0,0,16,8">
                    <TextBlock Style="{StaticResource Text.Section}" Text="ALGORITHM" Margin="0,0,0,4" />
                    <ComboBox x:Name="AlgorithmBox" MinWidth="100" SelectionChanged="Option_Changed">
                        <ComboBoxItem Content="SHA1" Tag="SHA1" />
                        <ComboBoxItem Content="SHA256" Tag="SHA256" />
                        <ComboBoxItem Content="SHA512" Tag="SHA512" />
                    </ComboBox>
                </StackPanel>
            </WrapPanel>
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,4,0,0">

                <Border Style="{StaticResource Card}" Padding="18" Margin="0,0,0,14">
                    <StackPanel>
                        <DockPanel>
                            <Button x:Name="CopyBtn"
                                    DockPanel.Dock="Right"
                                    VerticalAlignment="Top"
                                    Content="Copy"
                                    Click="Copy_Click" />
                            <TextBlock x:Name="CurrentCodeText"
                                       Style="{StaticResource Text.Title}"
                                       FontFamily="{StaticResource Font.Mono}"
                                       FontSize="38"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center" />
                        </DockPanel>

                        <Grid Height="4" Margin="0,14,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition x:Name="RemainingCol" Width="1*" />
                                <ColumnDefinition x:Name="ElapsedCol" Width="0*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="{StaticResource Brush.Accent}" CornerRadius="2" />
                            <Border Grid.Column="1" Background="{StaticResource Brush.Border}" CornerRadius="2" />
                        </Grid>
                        <TextBlock x:Name="CountdownText" Style="{StaticResource Text.Sub}" Margin="0,0,0,12" />

                        <WrapPanel>
                            <StackPanel Margin="0,0,28,0">
                                <TextBlock Style="{StaticResource Text.Section}" Text="PREVIOUS" Margin="0,0,0,2" />
                                <TextBlock x:Name="PrevCodeText"
                                           FontFamily="{StaticResource Font.Mono}"
                                           FontSize="16"
                                           Foreground="{StaticResource Brush.Fg2}" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Style="{StaticResource Text.Section}" Text="NEXT" Margin="0,0,0,2" />
                                <TextBlock x:Name="NextCodeText"
                                           FontFamily="{StaticResource Font.Mono}"
                                           FontSize="16"
                                           Foreground="{StaticResource Brush.Fg2}" />
                            </StackPanel>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <TextBlock Style="{StaticResource Text.Section}" Text="ENROLLMENT QR" Margin="0,0,0,8" />
                <Border Background="White"
                        CornerRadius="8"
                        Padding="10"
                        HorizontalAlignment="Left">
                    <Image x:Name="QrImage"
                           Width="130"
                           Height="130"
                           Stretch="Uniform"
                           SnapsToDevicePixels="True"
                           RenderOptions.BitmapScalingMode="NearestNeighbor" />
                </Border>

                <TextBlock Style="{StaticResource Text.Sub}"
                           Margin="0,14,0,0"
                           Text="Dev/testing helper — secrets are never stored." />
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
