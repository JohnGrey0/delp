<UserControl x:Class="Delp.App.Tools.Hashing.RandomStringView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="16">

        <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,6">
            <StackPanel Orientation="Horizontal" Margin="0,0,16,10">
                <TextBlock Text="Length" VerticalAlignment="Center" Margin="0,0,8,0" Style="{StaticResource Text.Sub}" />
                <TextBox x:Name="LengthBox" Width="60" Text="32" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,16,10">
                <TextBlock Text="Count" VerticalAlignment="Center" Margin="0,0,8,0" Style="{StaticResource Text.Sub}" />
                <TextBox x:Name="CountBox" Width="60" Text="5" />
            </StackPanel>
            <CheckBox x:Name="LowerBox" Content="a-z" IsChecked="True" Margin="0,0,16,10" />
            <CheckBox x:Name="UpperBox" Content="A-Z" IsChecked="True" Margin="0,0,16,10" />
            <CheckBox x:Name="DigitsBox" Content="0-9" IsChecked="True" Margin="0,0,16,10" />
            <CheckBox x:Name="SymbolsBox" Content="Symbols" Margin="0,0,16,10" />
            <CheckBox x:Name="ExcludeAmbiguousBox" Content="Exclude ambiguous (Il1O0o)" Margin="0,0,16,10" />
        </WrapPanel>

        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" Margin="0,0,8,0" Style="{StaticResource Text.Sub}" Text="Custom extra chars" />
            <Button DockPanel.Dock="Right" x:Name="GenerateBtn" Content="Generate" Style="{StaticResource Button.Primary}" Click="Generate_Click" Margin="8,0,0,0" />
            <TextBox x:Name="CustomBox" />
        </DockPanel>

        <TextBlock x:Name="ErrorText"
                   DockPanel.Dock="Bottom"
                   Margin="0,8,0,0"
                   Style="{StaticResource Text.Error}"
                   Visibility="Collapsed" />

        <DockPanel>
            <StackPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
                <TextBlock x:Name="EntropyNote" Style="{StaticResource Text.Sub}" />
            </StackPanel>
            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                <Button x:Name="CopyBtn" DockPanel.Dock="Right" Content="Copy" Click="Copy_Click" />
                <TextBlock VerticalAlignment="Center" Style="{StaticResource Text.Section}" Text="OUTPUT" />
            </DockPanel>
            <TextBox x:Name="OutputBox"
                     Style="{StaticResource TextBox.Mono}"
                     IsReadOnly="True" />
        </DockPanel>
    </DockPanel>
</UserControl>
