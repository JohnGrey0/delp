<UserControl x:Class="Delp.App.Tools.Hashing.NanoIdView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="16">

        <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,6">
            <StackPanel Orientation="Horizontal" Margin="0,0,16,10">
                <TextBlock Text="Size" VerticalAlignment="Center" Margin="0,0,8,0" Style="{StaticResource Text.Sub}" />
                <TextBox x:Name="SizeBox" Width="60" Text="21" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,16,10">
                <TextBlock Text="Count" VerticalAlignment="Center" Margin="0,0,8,0" Style="{StaticResource Text.Sub}" />
                <TextBox x:Name="CountBox" Width="60" Text="5" />
            </StackPanel>
            <Button x:Name="GenerateBtn" Content="Generate" Style="{StaticResource Button.Primary}" Click="Generate_Click" Margin="0,0,0,10" />
        </WrapPanel>

        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,4">
            <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" Margin="0,0,8,0" Style="{StaticResource Text.Sub}" Text="Alphabet" />
            <TextBox x:Name="AlphabetBox" />
        </DockPanel>
        <TextBlock DockPanel.Dock="Top"
                   Margin="0,0,0,12"
                   Style="{StaticResource Text.Sub}"
                   Text="Leave blank for the default 64-character A-Za-z0-9_- alphabet." />

        <TextBlock x:Name="ErrorText"
                   DockPanel.Dock="Bottom"
                   Margin="0,8,0,0"
                   Style="{StaticResource Text.Error}"
                   Visibility="Collapsed" />

        <DockPanel>
            <StackPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
                <TextBlock x:Name="CollisionNote" Style="{StaticResource Text.Sub}" />
            </StackPanel>
            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                <Button x:Name="CopyBtn" DockPanel.Dock="Right" Content="Copy" Click="Copy_Click" />
                <TextBlock VerticalAlignment="Center" Style="{StaticResource Text.Section}" Text="OUTPUT" />
            </DockPanel>
            <TextBox x:Name="OutputBox"
                     Style="{StaticResource TextBox.Mono}"
                     IsReadOnly="True" />
        </DockPanel>
    </DockPanel>
</UserControl>
