<UserControl x:Class="Delp.App.Tools.Hashing.Pbkdf2View"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="16">

        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock Style="{StaticResource Text.Section}" Text="PASSWORD" Margin="0,0,0,6" />
            <TextBox x:Name="PasswordBox"
                     Style="{StaticResource TextBox.Mono}"
                     AcceptsReturn="False"
                     TextWrapping="NoWrap"
                     Height="32"
                     VerticalContentAlignment="Center"
                     Margin="0,0,0,10" />

            <WrapPanel Margin="0,0,0,4">
                <StackPanel Margin="0,0,14,8">
                    <TextBlock Style="{StaticResource Text.Section}" Text="SALT (HEX)" Margin="0,0,0,4" />
                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="SaltBox"
                                 Width="200"
                                 Style="{StaticResource TextBox.Mono}"
                                 AcceptsReturn="False"
                                 TextWrapping="NoWrap"
                                 Height="32"
                                 VerticalContentAlignment="Center" />
                        <Button Content="Generate" Margin="8,0,0,0" Click="GenerateSalt_Click" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Margin="0,0,14,8">
                    <TextBlock Style="{StaticResource Text.Section}" Text="ITERATIONS" Margin="0,0,0,4" />
                    <TextBox x:Name="IterationsBox" Width="100" Text="600000" TextChanged="IterationsBox_TextChanged" />
                </StackPanel>

                <StackPanel Margin="0,0,14,8">
                    <TextBlock Style="{StaticResource Text.Section}" Text="ALGORITHM" Margin="0,0,0,4" />
                    <ComboBox x:Name="AlgoCombo" Width="100">
                        <ComboBoxItem Content="SHA-1" />
                        <ComboBoxItem Content="SHA-256" IsSelected="True" />
                        <ComboBoxItem Content="SHA-512" />
                    </ComboBox>
                </StackPanel>

                <StackPanel Margin="0,0,0,8">
                    <TextBlock Style="{StaticResource Text.Section}" Text="LENGTH (BYTES)" Margin="0,0,0,4" />
                    <TextBox x:Name="LengthBox" Width="80" Text="32" />
                </StackPanel>
            </WrapPanel>

            <TextBlock x:Name="IterationsWarning"
                       Style="{StaticResource Text.Sub}"
                       Foreground="{StaticResource Brush.Warning}"
                       Text="Below the OWASP-recommended minimum of 1,000 iterations."
                       Visibility="Collapsed"
                       Margin="0,0,0,8" />

            <Button x:Name="DeriveBtn"
                    Style="{StaticResource Button.Primary}"
                    Content="Derive"
                    HorizontalAlignment="Left"
                    Click="Derive_Click" />
        </StackPanel>

        <TextBlock x:Name="ErrorText"
                   DockPanel.Dock="Bottom"
                   Margin="0,8,0,0"
                   Style="{StaticResource Text.Error}"
                   Visibility="Collapsed" />

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <DockPanel Margin="0,0,0,6">
                    <Button x:Name="CopyHexBtn" DockPanel.Dock="Right" Content="Copy" Click="CopyHex_Click" />
                    <TextBlock VerticalAlignment="Center" Style="{StaticResource Text.Section}" Text="HEX" />
                </DockPanel>
                <TextBox x:Name="HexOutputBox"
                         Style="{StaticResource TextBox.Mono}"
                         IsReadOnly="True"
                         Height="56"
                         Margin="0,0,0,14" />

                <DockPanel Margin="0,0,0,6">
                    <Button x:Name="CopyBase64Btn" DockPanel.Dock="Right" Content="Copy" Click="CopyBase64_Click" />
                    <TextBlock VerticalAlignment="Center" Style="{StaticResource Text.Section}" Text="BASE64" />
                </DockPanel>
                <TextBox x:Name="Base64OutputBox"
                         Style="{StaticResource TextBox.Mono}"
                         IsReadOnly="True"
                         Height="56"
                         Margin="0,0,0,14" />

                <DockPanel Margin="0,0,0,6">
                    <Button x:Name="CopyPhcBtn" DockPanel.Dock="Right" Content="Copy" Click="CopyPhc_Click" />
                    <TextBlock VerticalAlignment="Center" Style="{StaticResource Text.Section}" Text="PHC STRING" />
                </DockPanel>
                <TextBox x:Name="PhcOutputBox"
                         Style="{StaticResource TextBox.Mono}"
                         IsReadOnly="True"
                         Height="56" />
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
