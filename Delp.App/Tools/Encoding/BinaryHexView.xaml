<UserControl x:Class="Delp.App.Tools.Encoding.BinaryHexView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="16">

        <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <CheckBox x:Name="SpacedBox"
                      Content="Space between bytes"
                      IsChecked="True"
                      Checked="Option_Changed"
                      Unchecked="Option_Changed"
                      Margin="0,0,16,4" />
            <CheckBox x:Name="UppercaseBox"
                      Content="Uppercase hex"
                      Checked="Option_Changed"
                      Unchecked="Option_Changed"
                      Margin="0,0,16,4" />
        </WrapPanel>

        <TextBlock x:Name="ErrorText"
                   DockPanel.Dock="Bottom"
                   Margin="0,8,0,0"
                   Style="{StaticResource Text.Error}"
                   Visibility="Collapsed" />

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <DockPanel Margin="0,0,0,6">
                    <Button x:Name="CopyTextBtn"
                            DockPanel.Dock="Right"
                            Content="Copy"
                            Click="CopyText_Click" />
                    <TextBlock VerticalAlignment="Center"
                               Style="{StaticResource Text.Section}"
                               Text="TEXT" />
                </DockPanel>
                <TextBox x:Name="TextPaneBox"
                         MinHeight="64"
                         Style="{StaticResource TextBox.Mono}"
                         TextChanged="TextPaneBox_TextChanged" />

                <DockPanel Margin="0,14,0,6">
                    <Button x:Name="CopyHexBtn"
                            DockPanel.Dock="Right"
                            Content="Copy"
                            Click="CopyHex_Click" />
                    <TextBlock VerticalAlignment="Center"
                               Style="{StaticResource Text.Section}"
                               Text="HEX" />
                </DockPanel>
                <TextBox x:Name="HexBox"
                         MinHeight="64"
                         Style="{StaticResource TextBox.Mono}"
                         TextChanged="HexBox_TextChanged" />

                <DockPanel Margin="0,14,0,6">
                    <Button x:Name="CopyBinaryBtn"
                            DockPanel.Dock="Right"
                            Content="Copy"
                            Click="CopyBinary_Click" />
                    <TextBlock VerticalAlignment="Center"
                               Style="{StaticResource Text.Section}"
                               Text="BINARY" />
                </DockPanel>
                <TextBox x:Name="BinaryBox"
                         MinHeight="64"
                         Style="{StaticResource TextBox.Mono}"
                         TextChanged="BinaryBox_TextChanged" />

                <DockPanel Margin="0,14,0,6">
                    <Button x:Name="CopyDecimalBtn"
                            DockPanel.Dock="Right"
                            Content="Copy"
                            Click="CopyDecimal_Click" />
                    <TextBlock VerticalAlignment="Center"
                               Style="{StaticResource Text.Section}"
                               Text="DECIMAL" />
                </DockPanel>
                <TextBox x:Name="DecimalBox"
                         MinHeight="64"
                         Style="{StaticResource TextBox.Mono}"
                         TextChanged="DecimalBox_TextChanged" />

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
