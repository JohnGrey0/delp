<UserControl x:Class="Delp.App.Tools.Encoding.UrlEncodeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="16">

        <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <RadioButton x:Name="ComponentMode"
                         Content="Component"
                         GroupName="UrlEncodeMode"
                         IsChecked="True"
                         Checked="Option_Changed"
                         Margin="0,0,16,4" />
            <RadioButton x:Name="FormDataMode"
                         Content="Form data (space → +)"
                         GroupName="UrlEncodeMode"
                         Checked="Option_Changed"
                         Margin="0,0,16,4" />
            <RadioButton x:Name="PreserveMode"
                         Content="Preserve URI chars"
                         GroupName="UrlEncodeMode"
                         Checked="Option_Changed"
                         Margin="0,0,16,4" />
        </WrapPanel>

        <TextBlock x:Name="ErrorText"
                   DockPanel.Dock="Bottom"
                   Margin="0,8,0,0"
                   Style="{StaticResource Text.Error}"
                   Visibility="Collapsed" />

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,6">
                <Button x:Name="CopyDecodedBtn"
                        DockPanel.Dock="Right"
                        Content="Copy"
                        Click="CopyDecoded_Click" />
                <TextBlock VerticalAlignment="Center"
                           Style="{StaticResource Text.Section}"
                           Text="DECODED" />
            </DockPanel>
            <TextBox x:Name="DecodedBox"
                     Grid.Row="1"
                     Style="{StaticResource TextBox.Mono}"
                     TextChanged="DecodedBox_TextChanged" />

            <DockPanel Grid.Row="2" Margin="0,14,0,6">
                <Button x:Name="CopyEncodedBtn"
                        DockPanel.Dock="Right"
                        Content="Copy"
                        Click="CopyEncoded_Click" />
                <TextBlock VerticalAlignment="Center"
                           Style="{StaticResource Text.Section}"
                           Text="ENCODED" />
            </DockPanel>
            <TextBox x:Name="EncodedBox"
                     Grid.Row="3"
                     Style="{StaticResource TextBox.Mono}"
                     TextChanged="EncodedBox_TextChanged" />
        </Grid>
    </DockPanel>
</UserControl>
