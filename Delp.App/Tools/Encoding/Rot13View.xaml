<UserControl x:Class="Delp.App.Tools.Encoding.Rot13View"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="16">

        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <WrapPanel>
                <TextBlock VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           Style="{StaticResource Text.Section}"
                           Text="SHIFT" />
                <TextBox x:Name="ShiftBox"
                         Width="64"
                         Text="13"
                         TextChanged="Option_Changed" />
            </WrapPanel>
            <TextBlock Margin="0,8,0,0"
                       Style="{StaticResource Text.Sub}"
                       Text="13 is its own inverse — applying ROT13 twice returns the original text." />
        </StackPanel>

        <TextBlock x:Name="ErrorText"
                   DockPanel.Dock="Bottom"
                   Margin="0,8,0,0"
                   Style="{StaticResource Text.Error}"
                   Visibility="Collapsed" />

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,6">
                <Button x:Name="CopyPlainBtn"
                        DockPanel.Dock="Right"
                        Content="Copy"
                        Click="CopyPlain_Click" />
                <TextBlock VerticalAlignment="Center"
                           Style="{StaticResource Text.Section}"
                           Text="PLAIN" />
            </DockPanel>
            <TextBox x:Name="PlainBox"
                     Grid.Row="1"
                     Style="{StaticResource TextBox.Mono}"
                     TextChanged="PlainBox_TextChanged" />

            <DockPanel Grid.Row="2" Margin="0,14,0,6">
                <Button x:Name="CopyShiftedBtn"
                        DockPanel.Dock="Right"
                        Content="Copy"
                        Click="CopyShifted_Click" />
                <TextBlock VerticalAlignment="Center"
                           Style="{StaticResource Text.Section}"
                           Text="SHIFTED" />
            </DockPanel>
            <TextBox x:Name="ShiftedBox"
                     Grid.Row="3"
                     Style="{StaticResource TextBox.Mono}"
                     TextChanged="ShiftedBox_TextChanged" />
        </Grid>
    </DockPanel>
</UserControl>
