<UserControl x:Class="Delp.App.Tools.Encoding.JwtDecoderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="16">

        <TextBlock DockPanel.Dock="Top"
                   Margin="0,0,0,10"
                   Style="{StaticResource Text.Sub}"
                   Text="Decode only — signatures are not verified." />

        <TextBlock x:Name="ErrorText"
                   DockPanel.Dock="Bottom"
                   Margin="0,8,0,0"
                   Style="{StaticResource Text.Error}"
                   Visibility="Collapsed" />

        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,14">
            <TextBlock DockPanel.Dock="Top"
                       Margin="0,0,0,6"
                       Style="{StaticResource Text.Section}"
                       Text="TOKEN" />
            <TextBox x:Name="TokenBox"
                     Height="90"
                     Style="{StaticResource TextBox.Mono}"
                     TextChanged="TokenBox_TextChanged" />
        </DockPanel>

        <TabControl>
            <TabItem Header="HEADER">
                <DockPanel>
                    <Button x:Name="CopyHeaderBtn"
                            DockPanel.Dock="Top"
                            HorizontalAlignment="Right"
                            Margin="0,0,0,6"
                            Content="Copy"
                            Click="CopyHeader_Click" />
                    <Border x:Name="HeaderEditorHost" Style="{StaticResource Card.Editor}" />
                </DockPanel>
            </TabItem>
            <TabItem Header="PAYLOAD">
                <DockPanel>
                    <Button x:Name="CopyPayloadBtn"
                            DockPanel.Dock="Top"
                            HorizontalAlignment="Right"
                            Margin="0,0,0,6"
                            Content="Copy"
                            Click="CopyPayload_Click" />
                    <Border x:Name="PayloadEditorHost" Style="{StaticResource Card.Editor}" />
                </DockPanel>
            </TabItem>
            <TabItem Header="CLAIMS">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="ClaimsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource Card}"
                                        Margin="0,0,0,6"
                                        Padding="10,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0"
                                                   Style="{StaticResource Text.Section}"
                                                   Text="{Binding Name}" />
                                        <TextBlock Grid.Row="0" Grid.Column="1"
                                                   Style="{StaticResource Text.Mono}"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding Value}" />
                                        <TextBlock Grid.Row="1" Grid.Column="1"
                                                   Margin="0,4,0,0"
                                                   TextWrapping="Wrap"
                                                   FontSize="12"
                                                   Foreground="{Binding NoteBrush}"
                                                   Text="{Binding Note}"
                                                   Visibility="{Binding NoteVisibility}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </DockPanel>
</UserControl>
