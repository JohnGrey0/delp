<UserControl x:Class="Delp.App.Tools.DevUtilities.ShellCheatSheetView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="16">

        <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,4">
            <TextBox x:Name="SearchBox"
                     Width="220"
                     Margin="0,0,8,10"
                     Style="{StaticResource TextBox.Search}"
                     Tag="Search tasks or commands…"
                     TextChanged="Filter_Changed" />
            <ComboBox x:Name="CategoryBox"
                      Width="170"
                      Margin="0,0,8,10"
                      SelectionChanged="Filter_Changed" />
        </WrapPanel>

        <TextBlock x:Name="StatusText"
                   DockPanel.Dock="Bottom"
                   Margin="0,10,0,0"
                   Style="{StaticResource Text.Sub}" />

        <!--
            Virtualizing ListBox (not ItemsControl-in-a-ScrollViewer): with ~81 result
            cards, a plain ItemsControl instantiates every card's visual tree up front.
            ListBox's default panel is a VirtualizingStackPanel and the theme sets
            VirtualizingPanel.ScrollUnit=Pixel on every ListBox, so only on-screen cards
            get realized; VirtualizationMode=Recycling reuses containers across scrolling
            and re-filtering instead of tearing them down and rebuilding.
        -->
        <ListBox x:Name="ResultsList"
                 VirtualizingPanel.VirtualizationMode="Recycling"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource Card}" Padding="14" Margin="0,0,4,10">
                        <StackPanel>
                            <TextBlock Text="{Binding Task}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8"
                                       Foreground="{StaticResource Brush.Fg0}" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition />
                                    <RowDefinition />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0"
                                           Text="bash $"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0"
                                           FontFamily="{StaticResource Font.Mono}"
                                           FontSize="12"
                                           MinWidth="46"
                                           Foreground="{StaticResource Brush.Fg2}" />
                                <TextBox Grid.Row="0" Grid.Column="1"
                                         Style="{StaticResource TextBox.Mono}"
                                         IsReadOnly="True"
                                         Text="{Binding Bash, Mode=OneWay}"
                                         Margin="0,0,10,0" />
                                <Button Grid.Row="0" Grid.Column="2"
                                        Content="Copy"
                                        Tag="Bash"
                                        Click="CopyCommand_Click" />

                                <TextBlock Grid.Row="1" Grid.Column="0"
                                           Text="PS &gt;"
                                           VerticalAlignment="Center"
                                           Margin="0,6,10,0"
                                           FontFamily="{StaticResource Font.Mono}"
                                           FontSize="12"
                                           MinWidth="46"
                                           Foreground="{StaticResource Brush.Fg2}" />
                                <TextBox Grid.Row="1" Grid.Column="1"
                                         Style="{StaticResource TextBox.Mono}"
                                         IsReadOnly="True"
                                         Text="{Binding PowerShell, Mode=OneWay}"
                                         Margin="0,6,10,0" />
                                <Button Grid.Row="1" Grid.Column="2"
                                        Content="Copy"
                                        Tag="PowerShell"
                                        Click="CopyCommand_Click"
                                        Margin="0,6,0,0" />
                            </Grid>

                            <TextBlock Text="{Binding Notes}" Margin="0,8,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource Text.Sub}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Notes}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

    </DockPanel>
</UserControl>
