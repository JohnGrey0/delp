<UserControl x:Class="Delp.App.Tools.DevUtilities.PortLookupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="16">

        <TextBox x:Name="SearchBox"
                 DockPanel.Dock="Top"
                 Margin="0,0,0,8"
                 Style="{StaticResource TextBox.Search}"
                 Tag="Search a port number, service, or description…"
                 TextChanged="SearchBox_TextChanged" />

        <TextBlock x:Name="CountText"
                   DockPanel.Dock="Bottom"
                   Margin="0,8,0,0"
                   Style="{StaticResource Text.Sub}" />

        <Border Style="{StaticResource Card.Editor}">
            <!-- ListBox (not ItemsControl+ScrollViewer) so ~140 rows are UI-virtualized. -->
            <ListBox x:Name="ResultsList"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.CanContentScroll="True">
                <ListBox.ItemContainerStyle>
                    <Style BasedOn="{StaticResource {x:Type ListBoxItem}}" TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="8,7" BorderThickness="0,0,0,1" BorderBrush="{StaticResource Brush.Border}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="52" />
                                    <ColumnDefinition Width="66" />
                                    <ColumnDefinition Width="1.1*" MinWidth="110" />
                                    <ColumnDefinition Width="2*" MinWidth="140" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           Margin="0,0,10,0"
                                           Style="{StaticResource Text.Mono}"
                                           Text="{Binding Port}" />
                                <TextBlock Grid.Column="1"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource Brush.Fg2}"
                                           FontSize="11"
                                           Text="{Binding Protocol}" />
                                <TextBlock Grid.Column="2"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"
                                           Text="{Binding Service}" />
                                <TextBlock Grid.Column="3"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource Text.Sub}"
                                           TextWrapping="Wrap"
                                           Text="{Binding Description}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>
    </DockPanel>
</UserControl>
