<UserControl x:Class="Delp.App.Tools.DevUtilities.GitignoreView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="16">

        <TextBox x:Name="SearchBox"
                 DockPanel.Dock="Top"
                 Margin="0,0,0,10"
                 Style="{StaticResource TextBox.Search}"
                 Tag="Search templates…"
                 TextChanged="Search_Changed" />

        <TextBlock x:Name="ErrorText"
                   DockPanel.Dock="Bottom"
                   Margin="0,8,0,0"
                   Style="{StaticResource Text.Error}"
                   Visibility="Collapsed" />

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="2*" MinHeight="110" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="3*" MinHeight="110" />
            </Grid.RowDefinitions>

            <!--
                A grouped checklist needs to scroll as one unit without trapping the mouse wheel:
                one outer ScrollViewer around plain, non-scrolling panels (StackPanel/WrapPanel),
                never a ListBox (or other self-scrolling control) nested inside a ScrollViewer.
            -->
            <Border Grid.Row="0" Style="{StaticResource Card}" Padding="12" Margin="0,0,0,8">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="ChecklistPanel" />
                </ScrollViewer>
            </Border>

            <DockPanel Grid.Row="1" Margin="0,0,0,12">
                <Button x:Name="ClearBtn" DockPanel.Dock="Right" Content="Clear" Click="Clear_Click" />
                <TextBlock x:Name="SelectedCountText" VerticalAlignment="Center" Style="{StaticResource Text.Sub}" />
            </DockPanel>

            <DockPanel Grid.Row="2" Margin="0,0,0,6">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="SaveBtn" Content="Save as…" Margin="0,0,8,0" Click="Save_Click" />
                    <Button x:Name="CopyBtn" Content="Copy" Click="Copy_Click" />
                </StackPanel>
                <TextBlock VerticalAlignment="Center" Style="{StaticResource Text.Section}" Text="OUTPUT" />
            </DockPanel>
            <Border x:Name="OutputHost" Grid.Row="3" Style="{StaticResource Card.Editor}" />
        </Grid>
    </DockPanel>
</UserControl>
