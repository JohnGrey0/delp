<UserControl x:Class="Delp.App.Tools.DevUtilities.MimeLookupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="16">

        <TextBox x:Name="SearchBox"
                 DockPanel.Dock="Top"
                 Margin="0,0,0,8"
                 Style="{StaticResource TextBox.Search}"
                 Tag="Type an extension or MIME type…"
                 TextChanged="SearchBox_TextChanged" />

        <TextBlock x:Name="CountText"
                   DockPanel.Dock="Bottom"
                   Margin="0,8,0,0"
                   Style="{StaticResource Text.Sub}" />

        <Border Style="{StaticResource Card.Editor}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="ResultsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8,7" BorderThickness="0,0,0,1" BorderBrush="{StaticResource Brush.Border}">
                                <DockPanel>
                                    <Button DockPanel.Dock="Right"
                                            Content="Copy"
                                            Tag="{Binding MimeType}"
                                            Click="CopyMime_Click" />
                                    <TextBlock VerticalAlignment="Center"
                                               Style="{StaticResource Text.Mono}">
                                        <Run Text="." /><Run Text="{Binding Extension, Mode=OneWay}" />
                                        <Run Text=" ↔ " Foreground="{StaticResource Brush.Fg2}" />
                                        <Run Text="{Binding MimeType, Mode=OneWay}" />
                                    </TextBlock>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </DockPanel>
</UserControl>
