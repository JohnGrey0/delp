<UserControl x:Class="Delp.App.Tools.DevUtilities.GitBranchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="16">

        <TextBlock x:Name="ErrorText"
                   DockPanel.Dock="Bottom"
                   Margin="0,8,0,0"
                   Style="{StaticResource Text.Error}"
                   Visibility="Collapsed" />

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Style="{StaticResource Text.Section}" Text="DESCRIPTION" Margin="0,0,0,4" />
                <TextBox x:Name="DescriptionBox" TextChanged="Input_Changed" Margin="0,0,0,10" />

                <WrapPanel>
                    <StackPanel Margin="0,0,16,10" MinWidth="140">
                        <TextBlock Style="{StaticResource Text.Section}" Text="TICKET (OPTIONAL)" Margin="0,0,0,4" />
                        <TextBox x:Name="TicketBox" TextChanged="Input_Changed" />
                    </StackPanel>
                    <StackPanel Margin="0,0,16,10" MinWidth="140">
                        <TextBlock Style="{StaticResource Text.Section}" Text="TYPE" Margin="0,0,0,4" />
                        <ComboBox x:Name="TypeCombo" SelectionChanged="TypeCombo_SelectionChanged">
                            <ComboBoxItem Content="feature" />
                            <ComboBoxItem Content="bugfix" />
                            <ComboBoxItem Content="hotfix" />
                            <ComboBoxItem Content="chore" />
                            <ComboBoxItem Content="release" />
                            <ComboBoxItem Content="Custom…" Tag="custom" />
                        </ComboBox>
                        <TextBox x:Name="CustomTypeBox"
                                 Margin="0,6,0,0"
                                 Visibility="Collapsed"
                                 TextChanged="Input_Changed" />
                    </StackPanel>
                </WrapPanel>

                <TextBlock Style="{StaticResource Text.Section}" Text="TEMPLATE (ADVANCED)" Margin="0,0,0,4" />
                <TextBox x:Name="TemplateBox"
                         Style="{StaticResource TextBox.Mono}"
                         AcceptsReturn="False"
                         Text="{}{type}/{ticket}-{slug}"
                         TextChanged="Input_Changed"
                         Margin="0,0,0,4" />
                <TextBlock Style="{StaticResource Text.Sub}"
                           Text="Placeholders: {type} {ticket} {slug}"
                           Margin="0,0,0,14" />

                <DockPanel Margin="0,0,0,6">
                    <Button x:Name="CopyNameBtn" DockPanel.Dock="Right" Content="Copy" Click="CopyName_Click" />
                    <TextBlock VerticalAlignment="Center" Style="{StaticResource Text.Section}" Text="BRANCH NAME" />
                </DockPanel>
                <TextBox x:Name="BranchNameBox"
                         IsReadOnly="True"
                         Style="{StaticResource TextBox.Mono}"
                         AcceptsReturn="False"
                         Margin="0,0,0,14" />

                <DockPanel Margin="0,0,0,6">
                    <Button x:Name="CopyCheckoutBtn" DockPanel.Dock="Right" Content="Copy" Click="CopyCheckout_Click" />
                    <TextBlock VerticalAlignment="Center" Style="{StaticResource Text.Section}" Text="CHECKOUT COMMAND" />
                </DockPanel>
                <TextBox x:Name="CheckoutBox"
                         IsReadOnly="True"
                         Style="{StaticResource TextBox.Mono}"
                         AcceptsReturn="False"
                         Margin="0,0,0,18" />

                <Border BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,1,0,0" Margin="0,0,0,16" />

                <TextBlock Style="{StaticResource Text.Section}" Text="CHECK A NAME" Margin="0,0,0,4" />
                <TextBox x:Name="CheckNameBox" TextChanged="Check_TextChanged" Margin="0,0,0,8" />
                <TextBlock x:Name="CheckResultText" TextWrapping="Wrap" />
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
