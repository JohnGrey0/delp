<UserControl x:Class="Delp.App.Tools.DevUtilities.CodeLinterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="16">

        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
            <TextBlock DockPanel.Dock="Left"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"
                       Style="{StaticResource Text.Sub}"
                       Text="Language" />
            <ComboBox x:Name="LanguageBox"
                      DockPanel.Dock="Left"
                      Width="180"
                      HorizontalAlignment="Left"
                      SelectionChanged="Language_Changed" />
        </DockPanel>

        <TextBlock DockPanel.Dock="Top"
                   Margin="0,0,0,10"
                   Style="{StaticResource Text.Sub}"
                   TextWrapping="Wrap"
                   Text="C#: full syntax + semantic checks (Roslyn) · JavaScript: parser diagnostics · JSON: parse validation · Python / Plain text: basic structural checks only." />

        <TextBlock x:Name="ErrorText"
                   DockPanel.Dock="Bottom"
                   Margin="0,8,0,0"
                   Style="{StaticResource Text.Error}"
                   Visibility="Collapsed" />

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="1.3*" MinHeight="90" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" MinHeight="80" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Margin="0,0,0,6"
                       Style="{StaticResource Text.Section}"
                       Text="CODE" />
            <Border x:Name="EditorHost"
                    Grid.Row="1"
                    Style="{StaticResource Card.Editor}" />

            <DockPanel Grid.Row="2" Margin="0,12,0,6">
                <TextBlock x:Name="StatusText"
                           DockPanel.Dock="Right"
                           VerticalAlignment="Center"
                           Style="{StaticResource Text.Sub}" />
                <TextBlock VerticalAlignment="Center"
                           Style="{StaticResource Text.Section}"
                           Text="ISSUES" />
            </DockPanel>

            <Border Grid.Row="3" Style="{StaticResource Card.Editor}">
                <ListBox x:Name="IssuesList"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.CanContentScroll="True"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling"
                         VirtualizingPanel.ScrollUnit="Pixel"
                         SelectionChanged="IssuesList_SelectionChanged">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                            <Setter Property="Padding" Value="6,5" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <DockPanel LastChildFill="True">
                                <Ellipse DockPanel.Dock="Left"
                                         Width="8" Height="8"
                                         Margin="2,4,8,0"
                                         VerticalAlignment="Top"
                                         Fill="{Binding SeverityBrush}" />
                                <TextBlock DockPanel.Dock="Left"
                                           Style="{StaticResource Text.Mono}"
                                           VerticalAlignment="Top"
                                           Margin="0,0,10,0"
                                           Text="{Binding Position}" />
                                <TextBlock TextWrapping="Wrap"
                                           VerticalAlignment="Top"
                                           Foreground="{StaticResource Brush.Fg1}"
                                           Text="{Binding Message}" />
                            </DockPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
