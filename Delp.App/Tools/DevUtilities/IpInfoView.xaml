<UserControl x:Class="Delp.App.Tools.DevUtilities.IpInfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="16">

        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock Margin="0,0,0,6"
                       Style="{StaticResource Text.Section}"
                       Text="IP ADDRESS OR CIDR" />
            <TextBox x:Name="InputBox"
                     Style="{StaticResource TextBox.Mono}"
                     AcceptsReturn="False"
                     Text="8.8.8.8"
                     TextChanged="InputBox_TextChanged" />
        </StackPanel>

        <TextBlock x:Name="ErrorText"
                   DockPanel.Dock="Bottom"
                   Margin="0,8,0,0"
                   Style="{StaticResource Text.Error}"
                   Visibility="Collapsed" />

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <Border x:Name="ResultCard"
                        Padding="14"
                        Margin="0,0,0,14"
                        Style="{StaticResource Card}">
                    <StackPanel>
                        <DockPanel>
                            <TextBlock x:Name="ClassificationBadge"
                                       DockPanel.Dock="Right"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Style="{StaticResource Text.Section}" />
                            <TextBlock x:Name="CanonicalText"
                                       Style="{StaticResource Text.Title}"
                                       TextWrapping="Wrap" />
                        </DockPanel>

                        <ItemsControl x:Name="RowsList" Margin="0,12,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1*" MinWidth="90" />
                                            <ColumnDefinition Width="2*" MinWidth="140" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Foreground="{StaticResource Brush.Fg2}"
                                                   Text="{Binding Label}" />
                                        <TextBlock Grid.Column="1"
                                                   Style="{StaticResource Text.Mono}"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding Value}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <TextBlock Margin="0,0,0,10"
                           Style="{StaticResource Text.Sub}"
                           Text="100% offline — no geolocation lookups are made for any address." />

                <DockPanel Margin="0,10,0,8">
                    <Button x:Name="RefreshAdaptersBtn"
                            DockPanel.Dock="Right"
                            Content="Refresh"
                            Click="RefreshAdapters_Click" />
                    <TextBlock VerticalAlignment="Center"
                               Style="{StaticResource Text.Section}"
                               Text="LOCAL ADAPTERS" />
                </DockPanel>
                <CheckBox x:Name="ShowAllBox"
                          Margin="0,0,0,10"
                          Content="Show all adapters (including down/disabled)"
                          Checked="ShowAllBox_Changed"
                          Unchecked="ShowAllBox_Changed" />

                <ItemsControl x:Name="AdaptersList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,8"
                                    Padding="12"
                                    Style="{StaticResource Card}">
                                <StackPanel>
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Right"
                                                   VerticalAlignment="Center"
                                                   Style="{StaticResource Text.Sub}"
                                                   Text="{Binding Status}" />
                                        <TextBlock FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"
                                                   Text="{Binding Name}" />
                                    </DockPanel>
                                    <TextBlock Margin="0,2,0,6"
                                               Style="{StaticResource Text.Sub}"
                                               TextWrapping="Wrap"
                                               Text="{Binding Description}" />
                                    <ItemsControl ItemsSource="{Binding IPv4Addresses}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Style="{StaticResource Text.Mono}" Text="{Binding}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <ItemsControl ItemsSource="{Binding IPv6Addresses}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Style="{StaticResource Text.Mono}"
                                                           Foreground="{StaticResource Brush.Fg1}"
                                                           TextTrimming="CharacterEllipsis"
                                                           Text="{Binding}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
