<UserControl x:Class="Delp.App.Tools.DevUtilities.ReferenceLookupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="16">
        <TabControl>
            <TabItem Header="HTTP STATUS">
                <DockPanel Margin="0,10,0,0">

                    <WrapPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBox x:Name="HttpSearchBox"
                                 Width="200"
                                 Margin="0,0,8,8"
                                 Style="{StaticResource TextBox.Search}"
                                 Tag="Search code, name, or summary…"
                                 TextChanged="HttpFilter_Changed" />
                        <ComboBox x:Name="HttpClassFilter"
                                  Width="110"
                                  Margin="0,0,0,8"
                                  SelectionChanged="HttpFilter_Changed">
                            <ComboBoxItem Content="All classes" IsSelected="True" />
                            <ComboBoxItem Content="1xx" />
                            <ComboBoxItem Content="2xx" />
                            <ComboBoxItem Content="3xx" />
                            <ComboBoxItem Content="4xx" />
                            <ComboBoxItem Content="5xx" />
                        </ComboBox>
                    </WrapPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.1*" MinWidth="130" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="2*" MinWidth="180" />
                        </Grid.ColumnDefinitions>

                        <DockPanel Grid.Column="0">
                            <TextBlock DockPanel.Dock="Top"
                                       Margin="0,0,0,6"
                                       Style="{StaticResource Text.Section}"
                                       Text="CODES" />
                            <TextBlock x:Name="HttpCountText"
                                       DockPanel.Dock="Bottom"
                                       Margin="0,6,0,0"
                                       Style="{StaticResource Text.Sub}" />
                            <ListBox x:Name="HttpResultsList"
                                     SelectionChanged="HttpResultsList_SelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Left"
                                                       MinWidth="34"
                                                       Style="{StaticResource Text.Mono}"
                                                       Text="{Binding Code}" />
                                            <TextBlock Margin="6,0,0,0"
                                                       VerticalAlignment="Center"
                                                       Text="{Binding Name}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </DockPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>

                        <Border Grid.Column="2"
                                Padding="16"
                                Style="{StaticResource Card}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="HttpDetailPanel">
                                    <TextBlock x:Name="HttpEmptyText"
                                               Style="{StaticResource Text.Sub}"
                                               Text="Select a status code on the left to see its guidance." />

                                    <StackPanel x:Name="HttpDetailContent" Visibility="Collapsed">
                                        <DockPanel>
                                            <TextBlock x:Name="HttpDetailClassBadge"
                                                       DockPanel.Dock="Right"
                                                       VerticalAlignment="Center"
                                                       Style="{StaticResource Text.Section}" />
                                            <TextBlock x:Name="HttpDetailCodeName"
                                                       Style="{StaticResource Text.Title}"
                                                       TextWrapping="Wrap" />
                                        </DockPanel>

                                        <TextBlock x:Name="HttpDetailSummary"
                                                   Margin="0,12,0,0"
                                                   Style="{StaticResource Text.Mono}"
                                                   TextWrapping="Wrap" />

                                        <TextBlock Margin="0,16,0,4"
                                                   Style="{StaticResource Text.Section}"
                                                   Text="GUIDANCE" />
                                        <TextBlock x:Name="HttpDetailWhen"
                                                   Style="{StaticResource Text.Sub}"
                                                   TextWrapping="Wrap" />

                                        <TextBlock x:Name="HttpDetailRfc"
                                                   Margin="0,16,0,0"
                                                   Style="{StaticResource Text.Sub}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </DockPanel>
            </TabItem>

            <TabItem Header="MIME TYPES">
                <DockPanel Margin="0,10,0,0">
                    <TextBox x:Name="MimeSearchBox"
                             DockPanel.Dock="Top"
                             Margin="0,0,0,8"
                             Style="{StaticResource TextBox.Search}"
                             Tag="Type an extension or MIME type…"
                             TextChanged="MimeSearchBox_TextChanged" />

                    <TextBlock x:Name="MimeCountText"
                               DockPanel.Dock="Bottom"
                               Margin="0,8,0,0"
                               Style="{StaticResource Text.Sub}" />

                    <Border Style="{StaticResource Card.Editor}">
                        <!-- ListBox (not ItemsControl+ScrollViewer) so ~280 rows are UI-virtualized. -->
                        <ListBox x:Name="MimeResultsList"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.CanContentScroll="True">
                            <ListBox.ItemContainerStyle>
                                <Style BasedOn="{StaticResource {x:Type ListBoxItem}}" TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8,7" BorderThickness="0,0,0,1" BorderBrush="{StaticResource Brush.Border}">
                                        <DockPanel>
                                            <Button DockPanel.Dock="Right"
                                                    Content="Copy"
                                                    Tag="{Binding MimeType}"
                                                    Click="CopyMime_Click" />
                                            <TextBlock VerticalAlignment="Center"
                                                       Style="{StaticResource Text.Mono}">
                                                <Run Text="." /><Run Text="{Binding Extension, Mode=OneWay}" />
                                                <Run Text=" ↔ " Foreground="{StaticResource Brush.Fg2}" />
                                                <Run Text="{Binding MimeType, Mode=OneWay}" />
                                            </TextBlock>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </DockPanel>
            </TabItem>

            <TabItem Header="PORTS">
                <DockPanel Margin="0,10,0,0">
                    <TextBox x:Name="PortSearchBox"
                             DockPanel.Dock="Top"
                             Margin="0,0,0,8"
                             Style="{StaticResource TextBox.Search}"
                             Tag="Search a port number, service, or description…"
                             TextChanged="PortSearchBox_TextChanged" />

                    <TextBlock x:Name="PortCountText"
                               DockPanel.Dock="Bottom"
                               Margin="0,8,0,0"
                               Style="{StaticResource Text.Sub}" />

                    <Border Style="{StaticResource Card.Editor}">
                        <!-- ListBox (not ItemsControl+ScrollViewer) so ~140 rows are UI-virtualized. -->
                        <ListBox x:Name="PortResultsList"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.CanContentScroll="True">
                            <ListBox.ItemContainerStyle>
                                <Style BasedOn="{StaticResource {x:Type ListBoxItem}}" TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8,7" BorderThickness="0,0,0,1" BorderBrush="{StaticResource Brush.Border}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="52" />
                                                <ColumnDefinition Width="66" />
                                                <ColumnDefinition Width="1.1*" MinWidth="110" />
                                                <ColumnDefinition Width="2*" MinWidth="140" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Right"
                                                       Margin="0,0,10,0"
                                                       Style="{StaticResource Text.Mono}"
                                                       Text="{Binding Port}" />
                                            <TextBlock Grid.Column="1"
                                                       VerticalAlignment="Center"
                                                       Foreground="{StaticResource Brush.Fg2}"
                                                       FontSize="11"
                                                       Text="{Binding Protocol}" />
                                            <TextBlock Grid.Column="2"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,10,0"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       Text="{Binding Service}" />
                                            <TextBlock Grid.Column="3"
                                                       VerticalAlignment="Center"
                                                       Style="{StaticResource Text.Sub}"
                                                       TextWrapping="Wrap"
                                                       Text="{Binding Description}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </DockPanel>
            </TabItem>

            <TabItem Header="USER AGENT">
                <DockPanel Margin="0,10,0,0">
                    <TextBlock x:Name="UaErrorText"
                               DockPanel.Dock="Bottom"
                               Margin="0,8,0,0"
                               Style="{StaticResource Text.Error}"
                               Visibility="Collapsed" />

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,6">
                                <Button x:Name="UaSampleBtn"
                                        DockPanel.Dock="Right"
                                        Content="Sample"
                                        Click="UaSample_Click" />
                                <TextBlock VerticalAlignment="Center"
                                           Style="{StaticResource Text.Section}"
                                           Text="USER AGENT STRING" />
                            </DockPanel>
                            <TextBox x:Name="UaInputBox"
                                     Style="{StaticResource TextBox.Mono}"
                                     MinHeight="64"
                                     Margin="0,0,0,14"
                                     TextChanged="UaInput_Changed" />

                            <Border x:Name="UaBotBadge"
                                    Style="{StaticResource Card}"
                                    Padding="10,7"
                                    Margin="0,0,0,12"
                                    Visibility="Collapsed">
                                <TextBlock x:Name="UaBotBadgeText"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource Brush.Warning}"
                                           TextWrapping="Wrap" />
                            </Border>

                            <ItemsControl x:Name="UaResultList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource Card}" Padding="10,7" Margin="0,0,0,4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="150" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Foreground="{StaticResource Brush.Fg1}"
                                                           Text="{Binding Label}" />
                                                <TextBlock Grid.Column="1"
                                                           FontFamily="{StaticResource Font.Mono}"
                                                           TextWrapping="Wrap"
                                                           Text="{Binding Value}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>

            <TabItem Header="CHMOD">
                <DockPanel Margin="0,10,0,0">
                    <TextBlock x:Name="ChmodErrorText"
                               DockPanel.Dock="Bottom"
                               Margin="0,8,0,0"
                               Style="{StaticResource Text.Error}"
                               Visibility="Collapsed" />

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Style="{StaticResource Text.Section}" Text="PERMISSIONS" Margin="0,0,0,8" />
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center" Style="{StaticResource Text.Sub}" Text="OWNER" />
                                <TextBlock Grid.Row="0" Grid.Column="2" HorizontalAlignment="Center" Style="{StaticResource Text.Sub}" Text="GROUP" />
                                <TextBlock Grid.Row="0" Grid.Column="3" HorizontalAlignment="Center" Style="{StaticResource Text.Sub}" Text="OTHER" />

                                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Read" />
                                <CheckBox x:Name="OwnerReadBox" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Center" IsChecked="True" Checked="Grid_Changed" Unchecked="Grid_Changed" />
                                <CheckBox x:Name="GroupReadBox" Grid.Row="1" Grid.Column="2" HorizontalAlignment="Center" IsChecked="True" Checked="Grid_Changed" Unchecked="Grid_Changed" />
                                <CheckBox x:Name="OtherReadBox" Grid.Row="1" Grid.Column="3" HorizontalAlignment="Center" IsChecked="True" Checked="Grid_Changed" Unchecked="Grid_Changed" />

                                <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Write" />
                                <CheckBox x:Name="OwnerWriteBox" Grid.Row="2" Grid.Column="1" HorizontalAlignment="Center" IsChecked="True" Checked="Grid_Changed" Unchecked="Grid_Changed" />
                                <CheckBox x:Name="GroupWriteBox" Grid.Row="2" Grid.Column="2" HorizontalAlignment="Center" Checked="Grid_Changed" Unchecked="Grid_Changed" />
                                <CheckBox x:Name="OtherWriteBox" Grid.Row="2" Grid.Column="3" HorizontalAlignment="Center" Checked="Grid_Changed" Unchecked="Grid_Changed" />

                                <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="Execute" />
                                <CheckBox x:Name="OwnerExecBox" Grid.Row="3" Grid.Column="1" HorizontalAlignment="Center" IsChecked="True" Checked="Grid_Changed" Unchecked="Grid_Changed" />
                                <CheckBox x:Name="GroupExecBox" Grid.Row="3" Grid.Column="2" HorizontalAlignment="Center" IsChecked="True" Checked="Grid_Changed" Unchecked="Grid_Changed" />
                                <CheckBox x:Name="OtherExecBox" Grid.Row="3" Grid.Column="3" HorizontalAlignment="Center" IsChecked="True" Checked="Grid_Changed" Unchecked="Grid_Changed" />
                            </Grid>

                            <WrapPanel Margin="0,10,0,14">
                                <CheckBox x:Name="SetuidBox" Content="Setuid" Margin="0,0,16,4" Checked="Grid_Changed" Unchecked="Grid_Changed" />
                                <CheckBox x:Name="SetgidBox" Content="Setgid" Margin="0,0,16,4" Checked="Grid_Changed" Unchecked="Grid_Changed" />
                                <CheckBox x:Name="StickyBox" Content="Sticky" Margin="0,0,0,4" Checked="Grid_Changed" Unchecked="Grid_Changed" />
                            </WrapPanel>

                            <TextBlock Style="{StaticResource Text.Section}" Text="OCTAL" Margin="0,0,0,4" />
                            <TextBox x:Name="OctalBox" FontFamily="{StaticResource Font.Mono}" Margin="0,0,0,14" TextChanged="Octal_Changed" />

                            <TextBlock Style="{StaticResource Text.Section}" Text="SYMBOLIC" Margin="0,0,0,4" />
                            <TextBox x:Name="SymbolicBox" FontFamily="{StaticResource Font.Mono}" Margin="0,0,0,14" TextChanged="Symbolic_Changed" />

                            <DockPanel Margin="0,0,0,6">
                                <Button x:Name="CopyCommandBtn" DockPanel.Dock="Right" Content="Copy" Click="CopyCommand_Click" />
                                <TextBlock VerticalAlignment="Center" Style="{StaticResource Text.Section}" Text="COMMAND LINE" />
                            </DockPanel>
                            <TextBox x:Name="CommandBox" FontFamily="{StaticResource Font.Mono}" IsReadOnly="True" />
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>

            <TabItem Header="BYTES">
                <DockPanel Margin="0,10,0,0">
                    <TextBlock x:Name="BytesErrorText"
                               DockPanel.Dock="Bottom"
                               Margin="0,8,0,0"
                               Style="{StaticResource Text.Error}"
                               Visibility="Collapsed" />

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <WrapPanel Margin="0,0,0,14">
                                <StackPanel Margin="0,0,10,8" MinWidth="120">
                                    <TextBlock Style="{StaticResource Text.Section}" Text="VALUE" Margin="0,0,0,4" />
                                    <TextBox x:Name="ByteValueBox" Text="1" TextChanged="Bytes_Changed" />
                                </StackPanel>
                                <StackPanel Margin="0,0,0,8" MinWidth="110">
                                    <TextBlock Style="{StaticResource Text.Section}" Text="UNIT" Margin="0,0,0,4" />
                                    <ComboBox x:Name="ByteUnitCombo" SelectionChanged="Bytes_Changed">
                                        <ComboBoxItem Content="B" Tag="B" />
                                        <ComboBoxItem Content="KB" Tag="KB" />
                                        <ComboBoxItem Content="MB" Tag="MB" IsSelected="True" />
                                        <ComboBoxItem Content="GB" Tag="GB" />
                                        <ComboBoxItem Content="TB" Tag="TB" />
                                        <ComboBoxItem Content="KiB" Tag="KiB" />
                                        <ComboBoxItem Content="MiB" Tag="MiB" />
                                        <ComboBoxItem Content="GiB" Tag="GiB" />
                                        <ComboBoxItem Content="TiB" Tag="TiB" />
                                        <ComboBoxItem Content="bit" Tag="Bit" />
                                        <ComboBoxItem Content="Kbit" Tag="Kbit" />
                                        <ComboBoxItem Content="Mbit" Tag="Mbit" />
                                        <ComboBoxItem Content="Gbit" Tag="Gbit" />
                                    </ComboBox>
                                </StackPanel>
                            </WrapPanel>

                            <TextBlock Style="{StaticResource Text.Section}" Text="EQUIVALENTS" Margin="0,0,0,6" />
                            <ItemsControl x:Name="ByteEquivalentsList" Margin="0,0,0,18">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource Card}" Padding="10,7" Margin="0,0,0,4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="70" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Foreground="{StaticResource Brush.Fg1}"
                                                           Text="{Binding Label}" />
                                                <TextBlock Grid.Column="1"
                                                           FontFamily="{StaticResource Font.Mono}"
                                                           HorizontalAlignment="Right"
                                                           Text="{Binding Value}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Style="{StaticResource Text.Section}" Text="TRANSFER TIME" Margin="0,0,0,6" />
                            <ItemsControl x:Name="TransferTimeList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource Card}" Padding="10,7" Margin="0,0,0,4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="90" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Foreground="{StaticResource Brush.Fg1}"
                                                           Text="{Binding RateLabel}" />
                                                <TextBlock Grid.Column="1"
                                                           FontFamily="{StaticResource Font.Mono}"
                                                           HorizontalAlignment="Right"
                                                           Text="{Binding Duration}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</UserControl>
