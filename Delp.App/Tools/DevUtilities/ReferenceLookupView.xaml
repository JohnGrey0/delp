<UserControl x:Class="Delp.App.Tools.DevUtilities.ReferenceLookupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="16">
        <TabControl>
            <TabItem Header="HTTP STATUS">
                <DockPanel Margin="0,10,0,0">

                    <WrapPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBox x:Name="HttpSearchBox"
                                 Width="200"
                                 Margin="0,0,8,8"
                                 Style="{StaticResource TextBox.Search}"
                                 Tag="Search code, name, or summary…"
                                 TextChanged="HttpFilter_Changed" />
                        <ComboBox x:Name="HttpClassFilter"
                                  Width="110"
                                  Margin="0,0,0,8"
                                  SelectionChanged="HttpFilter_Changed">
                            <ComboBoxItem Content="All classes" IsSelected="True" />
                            <ComboBoxItem Content="1xx" />
                            <ComboBoxItem Content="2xx" />
                            <ComboBoxItem Content="3xx" />
                            <ComboBoxItem Content="4xx" />
                            <ComboBoxItem Content="5xx" />
                        </ComboBox>
                    </WrapPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.1*" MinWidth="130" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="2*" MinWidth="180" />
                        </Grid.ColumnDefinitions>

                        <DockPanel Grid.Column="0">
                            <TextBlock DockPanel.Dock="Top"
                                       Margin="0,0,0,6"
                                       Style="{StaticResource Text.Section}"
                                       Text="CODES" />
                            <TextBlock x:Name="HttpCountText"
                                       DockPanel.Dock="Bottom"
                                       Margin="0,6,0,0"
                                       Style="{StaticResource Text.Sub}" />
                            <ListBox x:Name="HttpResultsList"
                                     SelectionChanged="HttpResultsList_SelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Left"
                                                       MinWidth="34"
                                                       Style="{StaticResource Text.Mono}"
                                                       Text="{Binding Code}" />
                                            <TextBlock Margin="6,0,0,0"
                                                       VerticalAlignment="Center"
                                                       Text="{Binding Name}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </DockPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>

                        <Border Grid.Column="2"
                                Padding="16"
                                Style="{StaticResource Card}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="HttpDetailPanel">
                                    <TextBlock x:Name="HttpEmptyText"
                                               Style="{StaticResource Text.Sub}"
                                               Text="Select a status code on the left to see its guidance." />

                                    <StackPanel x:Name="HttpDetailContent" Visibility="Collapsed">
                                        <DockPanel>
                                            <TextBlock x:Name="HttpDetailClassBadge"
                                                       DockPanel.Dock="Right"
                                                       VerticalAlignment="Center"
                                                       Style="{StaticResource Text.Section}" />
                                            <TextBlock x:Name="HttpDetailCodeName"
                                                       Style="{StaticResource Text.Title}"
                                                       TextWrapping="Wrap" />
                                        </DockPanel>

                                        <TextBlock x:Name="HttpDetailSummary"
                                                   Margin="0,12,0,0"
                                                   Style="{StaticResource Text.Mono}"
                                                   TextWrapping="Wrap" />

                                        <TextBlock Margin="0,16,0,4"
                                                   Style="{StaticResource Text.Section}"
                                                   Text="GUIDANCE" />
                                        <TextBlock x:Name="HttpDetailWhen"
                                                   Style="{StaticResource Text.Sub}"
                                                   TextWrapping="Wrap" />

                                        <TextBlock x:Name="HttpDetailRfc"
                                                   Margin="0,16,0,0"
                                                   Style="{StaticResource Text.Sub}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </DockPanel>
            </TabItem>

            <TabItem Header="MIME TYPES">
                <DockPanel Margin="0,10,0,0">
                    <TextBox x:Name="MimeSearchBox"
                             DockPanel.Dock="Top"
                             Margin="0,0,0,8"
                             Style="{StaticResource TextBox.Search}"
                             Tag="Type an extension or MIME type…"
                             TextChanged="MimeSearchBox_TextChanged" />

                    <TextBlock x:Name="MimeCountText"
                               DockPanel.Dock="Bottom"
                               Margin="0,8,0,0"
                               Style="{StaticResource Text.Sub}" />

                    <Border Style="{StaticResource Card.Editor}">
                        <!-- ListBox (not ItemsControl+ScrollViewer) so ~280 rows are UI-virtualized. -->
                        <ListBox x:Name="MimeResultsList"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.CanContentScroll="True">
                            <ListBox.ItemContainerStyle>
                                <Style BasedOn="{StaticResource {x:Type ListBoxItem}}" TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8,7" BorderThickness="0,0,0,1" BorderBrush="{StaticResource Brush.Border}">
                                        <DockPanel>
                                            <Button DockPanel.Dock="Right"
                                                    Content="Copy"
                                                    Tag="{Binding MimeType}"
                                                    Click="CopyMime_Click" />
                                            <TextBlock VerticalAlignment="Center"
                                                       Style="{StaticResource Text.Mono}">
                                                <Run Text="." /><Run Text="{Binding Extension, Mode=OneWay}" />
                                                <Run Text=" ↔ " Foreground="{StaticResource Brush.Fg2}" />
                                                <Run Text="{Binding MimeType, Mode=OneWay}" />
                                            </TextBlock>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </DockPanel>
            </TabItem>

            <TabItem Header="PORTS">
                <DockPanel Margin="0,10,0,0">
                    <TextBox x:Name="PortSearchBox"
                             DockPanel.Dock="Top"
                             Margin="0,0,0,8"
                             Style="{StaticResource TextBox.Search}"
                             Tag="Search a port number, service, or description…"
                             TextChanged="PortSearchBox_TextChanged" />

                    <TextBlock x:Name="PortCountText"
                               DockPanel.Dock="Bottom"
                               Margin="0,8,0,0"
                               Style="{StaticResource Text.Sub}" />

                    <Border Style="{StaticResource Card.Editor}">
                        <!-- ListBox (not ItemsControl+ScrollViewer) so ~140 rows are UI-virtualized. -->
                        <ListBox x:Name="PortResultsList"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.CanContentScroll="True">
                            <ListBox.ItemContainerStyle>
                                <Style BasedOn="{StaticResource {x:Type ListBoxItem}}" TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8,7" BorderThickness="0,0,0,1" BorderBrush="{StaticResource Brush.Border}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="52" />
                                                <ColumnDefinition Width="66" />
                                                <ColumnDefinition Width="1.1*" MinWidth="110" />
                                                <ColumnDefinition Width="2*" MinWidth="140" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Right"
                                                       Margin="0,0,10,0"
                                                       Style="{StaticResource Text.Mono}"
                                                       Text="{Binding Port}" />
                                            <TextBlock Grid.Column="1"
                                                       VerticalAlignment="Center"
                                                       Foreground="{StaticResource Brush.Fg2}"
                                                       FontSize="11"
                                                       Text="{Binding Protocol}" />
                                            <TextBlock Grid.Column="2"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,10,0"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       Text="{Binding Service}" />
                                            <TextBlock Grid.Column="3"
                                                       VerticalAlignment="Center"
                                                       Style="{StaticResource Text.Sub}"
                                                       TextWrapping="Wrap"
                                                       Text="{Binding Description}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </DockPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</UserControl>
