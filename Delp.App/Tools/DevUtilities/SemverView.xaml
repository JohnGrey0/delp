<UserControl x:Class="Delp.App.Tools.DevUtilities.SemverView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="16">

        <TextBlock x:Name="ErrorText"
                   DockPanel.Dock="Bottom"
                   Margin="0,8,0,0"
                   Style="{StaticResource Text.Error}"
                   Visibility="Collapsed" />

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <WrapPanel>
                    <StackPanel Margin="0,0,16,10" MinWidth="140">
                        <TextBlock Style="{StaticResource Text.Section}" Text="VERSION A" Margin="0,0,0,4" />
                        <TextBox x:Name="VersionABox"
                                 Style="{StaticResource TextBox.Mono}"
                                 AcceptsReturn="False"
                                 Text="1.2.3"
                                 TextChanged="Compare_Changed" />
                    </StackPanel>
                    <StackPanel Margin="0,0,0,10" MinWidth="140">
                        <TextBlock Style="{StaticResource Text.Section}" Text="VERSION B" Margin="0,0,0,4" />
                        <TextBox x:Name="VersionBBox"
                                 Style="{StaticResource TextBox.Mono}"
                                 AcceptsReturn="False"
                                 Text="1.3.0"
                                 TextChanged="Compare_Changed" />
                    </StackPanel>
                </WrapPanel>

                <TextBlock x:Name="VerdictText"
                           FontFamily="{StaticResource Font.Mono}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Margin="0,10,0,4"
                           TextWrapping="Wrap" />
                <TextBlock x:Name="ExplanationText"
                           Style="{StaticResource Text.Sub}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,14" />

                <TextBlock Style="{StaticResource Text.Section}" Text="BREAKDOWN" Margin="0,0,0,6" />
                <ItemsControl x:Name="BreakdownList" Margin="0,0,0,18">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource Card}" Padding="10,7" Margin="0,0,0,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Part}" Foreground="{StaticResource Brush.Fg1}" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding A}"
                                               FontFamily="{StaticResource Font.Mono}"
                                               Foreground="{Binding AColor}"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding B}"
                                               FontFamily="{StaticResource Font.Mono}"
                                               Foreground="{Binding BColor}"
                                               TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,1,0,0" Margin="0,0,0,16" />

                <TextBlock Style="{StaticResource Text.Section}" Text="RANGE CHECK" Margin="0,0,0,4" />
                <WrapPanel>
                    <StackPanel Margin="0,0,16,8" MinWidth="140">
                        <TextBlock Style="{StaticResource Text.Sub}" Text="Version" Margin="0,0,0,4" />
                        <TextBox x:Name="RangeVersionBox"
                                 Style="{StaticResource TextBox.Mono}"
                                 AcceptsReturn="False"
                                 Text="1.5.0"
                                 TextChanged="Range_Changed" />
                    </StackPanel>
                    <StackPanel Margin="0,0,0,8" MinWidth="160">
                        <TextBlock Style="{StaticResource Text.Sub}" Text="Range" Margin="0,0,0,4" />
                        <TextBox x:Name="RangeExprBox"
                                 Style="{StaticResource TextBox.Mono}"
                                 AcceptsReturn="False"
                                 Text="^1.0.0"
                                 TextChanged="Range_Changed" />
                    </StackPanel>
                </WrapPanel>
                <TextBlock x:Name="RangeResultText" TextWrapping="Wrap" Margin="0,4,0,4" />
                <TextBlock Style="{StaticResource Text.Sub}"
                           Text="Supported: ^x.y.z  ~x.y.z  &gt;=  &gt;  &lt;=  &lt;  =  and space-joined AND, e.g. &quot;&gt;=1.0.0 &lt;2.0.0&quot;."
                           TextWrapping="Wrap" />
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
