<UserControl x:Class="Delp.App.Tools.WebDev.MinifyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="16">

        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
            <TextBlock VerticalAlignment="Center"
                       Margin="0,0,10,0"
                       Style="{StaticResource Text.Section}"
                       Text="LANGUAGE" />
            <ComboBox x:Name="LanguageBox"
                      Width="140"
                      HorizontalAlignment="Left"
                      SelectionChanged="LanguageBox_SelectionChanged" />
        </DockPanel>

        <WrapPanel x:Name="HtmlOptionsPanel"
                   DockPanel.Dock="Top"
                   Margin="0,0,0,10"
                   Visibility="Collapsed">
            <CheckBox x:Name="RemoveCommentsBox"
                      Margin="0,0,16,4"
                      Content="Remove comments"
                      IsChecked="True" />
            <CheckBox x:Name="CollapseWhitespaceBox"
                      Margin="0,0,16,4"
                      Content="Collapse whitespace"
                      IsChecked="True" />
        </WrapPanel>

        <TextBlock x:Name="JsNoteText"
                   DockPanel.Dock="Top"
                   Margin="0,0,0,10"
                   Style="{StaticResource Text.Sub}"
                   Text="Classic minifier — very new syntax (e.g. class fields, ??=) may be unsupported."
                   Visibility="Collapsed" />

        <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,10">
            <Button x:Name="MinifyBtn"
                    Margin="0,0,8,8"
                    Click="Minify_Click"
                    Content="Minify"
                    Style="{StaticResource Button.Primary}" />
            <Button x:Name="BeautifyBtn"
                    Margin="0,0,8,8"
                    Click="Beautify_Click"
                    Content="Beautify"
                    Visibility="Collapsed" />
        </WrapPanel>

        <TextBlock x:Name="StatusText"
                   DockPanel.Dock="Top"
                   Margin="0,0,0,10"
                   Style="{StaticResource Text.Sub}" />

        <TextBlock x:Name="ErrorsText"
                   DockPanel.Dock="Bottom"
                   Margin="0,8,0,0"
                   Style="{StaticResource Text.Error}"
                   Visibility="Collapsed" />

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Margin="0,0,0,6" Style="{StaticResource Text.Section}" Text="INPUT" />
            <Border x:Name="InputEditorHost"
                    Grid.Row="1"
                    Margin="0,0,0,14"
                    MinHeight="120"
                    Style="{StaticResource Card.Editor}" />

            <DockPanel Grid.Row="2" Margin="0,0,0,6">
                <Button x:Name="CopyOutputBtn" DockPanel.Dock="Right" Content="Copy" Click="CopyOutput_Click" />
                <TextBlock VerticalAlignment="Center" Style="{StaticResource Text.Section}" Text="OUTPUT" />
            </DockPanel>
            <Border x:Name="OutputEditorHost"
                    Grid.Row="3"
                    MinHeight="120"
                    Style="{StaticResource Card.Editor}" />
        </Grid>
    </DockPanel>
</UserControl>
