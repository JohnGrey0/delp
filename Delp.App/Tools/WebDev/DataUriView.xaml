<UserControl x:Class="Delp.App.Tools.WebDev.DataUriView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="16">

        <TextBlock x:Name="ErrorText"
                   DockPanel.Dock="Bottom"
                   Margin="0,8,0,0"
                   Style="{StaticResource Text.Error}"
                   Visibility="Collapsed" />

        <TabControl>
            <TabItem Header="ENCODE">
                <DockPanel Margin="0,12,0,0">

                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                        <RadioButton x:Name="FileModeRadio"
                                     Content="File"
                                     GroupName="EncSource"
                                     IsChecked="True"
                                     Checked="Mode_Changed"
                                     Margin="0,0,16,0" />
                        <RadioButton x:Name="TextModeRadio"
                                     Content="Text"
                                     GroupName="EncSource"
                                     Checked="Mode_Changed" />
                    </StackPanel>

                    <Border x:Name="FilePanel"
                            DockPanel.Dock="Top"
                            Style="{StaticResource Card}"
                            Padding="16"
                            Margin="0,0,0,10"
                            AllowDrop="True"
                            DragOver="FilePanel_DragOver"
                            Drop="FilePanel_Drop">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Style="{StaticResource Text.Sub}"
                                       HorizontalAlignment="Center"
                                       Text="Drop a file here, or" />
                            <Button Content="Browse…"
                                    HorizontalAlignment="Center"
                                    Margin="0,8,0,0"
                                    Click="Browse_Click" />
                            <TextBlock x:Name="FileNameText"
                                       Style="{StaticResource Text.Sub}"
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>

                    <TextBox x:Name="TextInputBox"
                             DockPanel.Dock="Top"
                             Style="{StaticResource TextBox.Mono}"
                             Height="90"
                             Margin="0,0,0,10"
                             Visibility="Collapsed"
                             TextChanged="TextInput_Changed" />

                    <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal" Margin="0,0,16,6">
                            <TextBlock VerticalAlignment="Center"
                                       Style="{StaticResource Text.Section}"
                                       Text="MIME TYPE"
                                       Margin="0,0,8,0" />
                            <TextBox x:Name="MimeBox" Width="200" TextChanged="Mime_Changed" />
                        </StackPanel>
                        <CheckBox x:Name="TextBase64Box"
                                  Content="Base64 (instead of percent-encoding)"
                                  Visibility="Collapsed"
                                  VerticalAlignment="Center"
                                  Margin="0,0,0,6"
                                  Checked="Option_Changed"
                                  Unchecked="Option_Changed" />
                    </WrapPanel>

                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                        <Button x:Name="CopyEncodedBtn"
                                DockPanel.Dock="Right"
                                Content="Copy"
                                Click="CopyEncoded_Click" />
                        <TextBlock VerticalAlignment="Center"
                                   Style="{StaticResource Text.Section}"
                                   Text="DATA URI" />
                    </DockPanel>
                    <TextBox x:Name="EncodedBox"
                             DockPanel.Dock="Top"
                             Style="{StaticResource TextBox.Mono}"
                             IsReadOnly="True"
                             MinHeight="90" />
                    <TextBlock x:Name="EncodedSizeText"
                               Style="{StaticResource Text.Sub}"
                               Margin="0,6,0,0" />
                </DockPanel>
            </TabItem>

            <TabItem Header="DECODE">
                <DockPanel Margin="0,12,0,0">
                    <TextBlock DockPanel.Dock="Top"
                               Style="{StaticResource Text.Section}"
                               Text="DATA URI"
                               Margin="0,0,0,6" />
                    <TextBox x:Name="DecodeInputBox"
                             DockPanel.Dock="Top"
                             Style="{StaticResource TextBox.Mono}"
                             Height="90"
                             Margin="0,0,0,10"
                             TextChanged="DecodeInput_Changed" />

                    <Border DockPanel.Dock="Top" Style="{StaticResource Card}" Padding="12" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock x:Name="DecodeMimeText" Style="{StaticResource Text.Mono}" />
                            <TextBlock x:Name="DecodeSizeText" Style="{StaticResource Text.Sub}" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>

                    <Button x:Name="SaveAsBtn"
                            DockPanel.Dock="Top"
                            Content="Save as…"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,10"
                            IsEnabled="False"
                            Click="SaveAs_Click" />

                    <Border Style="{StaticResource Card.Editor}">
                        <Image x:Name="DecodePreviewImage" Stretch="Uniform" />
                    </Border>
                </DockPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</UserControl>
