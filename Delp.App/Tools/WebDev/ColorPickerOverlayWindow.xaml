<Window x:Class="Delp.App.Tools.WebDev.ColorPickerOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#01000000"
        ShowInTaskbar="False"
        Topmost="True"
        Cursor="Cross"
        ResizeMode="NoResize">
    <Canvas x:Name="RootCanvas">
        <Border x:Name="InfoCard"
                Background="#F0181B20"
                BorderBrush="#38FFFFFF"
                BorderThickness="1"
                CornerRadius="8"
                Padding="10,8"
                IsHitTestVisible="False">
            <StackPanel Orientation="Horizontal">
                <Border x:Name="Swatch"
                        Width="28" Height="28"
                        CornerRadius="5"
                        BorderBrush="#38FFFFFF"
                        BorderThickness="1" />
                <TextBlock x:Name="HexLabel"
                           Margin="10,0,0,0"
                           VerticalAlignment="Center"
                           FontFamily="Cascadia Mono, Cascadia Code, Consolas"
                           FontSize="13"
                           Foreground="White"
                           Text="#000000" />
            </StackPanel>
        </Border>
    </Canvas>
</Window>
