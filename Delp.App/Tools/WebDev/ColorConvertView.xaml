<UserControl x:Class="Delp.App.Tools.WebDev.ColorConvertView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="16">

        <TextBlock x:Name="ErrorText"
                   DockPanel.Dock="Bottom"
                   Margin="0,8,0,0"
                   Style="{StaticResource Text.Error}"
                   Visibility="Collapsed" />

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>

                <StackPanel Margin="0,0,0,16">
                    <Button x:Name="PickButton"
                            Style="{StaticResource Button.Primary}"
                            HorizontalAlignment="Left"
                            Content="Pick from screen"
                            Click="PickButton_Click" />
                    <TextBlock Margin="0,8,0,0"
                               Style="{StaticResource Text.Sub}"
                               Text="Multi-monitor supported. Esc cancels picking." />
                </StackPanel>

                <TextBlock Margin="0,0,0,6"
                           Style="{StaticResource Text.Section}"
                           Text="COLOR (#hex, rgb(), hsl(), hsb()/hsv())" />
                <TextBox x:Name="InputBox"
                         Margin="0,0,0,14"
                         Text="#336699"
                         TextChanged="InputBox_TextChanged" />

                <WrapPanel Margin="0,0,0,4">
                    <Border x:Name="Swatch"
                            Width="64" Height="64"
                            Margin="0,0,18,10"
                            BorderBrush="{StaticResource Brush.Border}"
                            BorderThickness="1"
                            CornerRadius="10" />

                    <StackPanel Margin="0,0,10,10" Orientation="Vertical" Width="60">
                        <TextBlock Style="{StaticResource Text.Section}" Text="R" />
                        <TextBox x:Name="RBox" TextChanged="Channel_TextChanged" />
                    </StackPanel>
                    <StackPanel Margin="0,0,10,10" Orientation="Vertical" Width="60">
                        <TextBlock Style="{StaticResource Text.Section}" Text="G" />
                        <TextBox x:Name="GBox" TextChanged="Channel_TextChanged" />
                    </StackPanel>
                    <StackPanel Margin="0,0,10,10" Orientation="Vertical" Width="60">
                        <TextBlock Style="{StaticResource Text.Section}" Text="B" />
                        <TextBox x:Name="BBox" TextChanged="Channel_TextChanged" />
                    </StackPanel>
                    <StackPanel Margin="0,0,10,10" Orientation="Vertical" Width="60">
                        <TextBlock Style="{StaticResource Text.Section}" Text="A" />
                        <TextBox x:Name="ABox" TextChanged="Channel_TextChanged" />
                    </StackPanel>
                </WrapPanel>

                <DockPanel Margin="0,10,0,6">
                    <Button x:Name="CopyHexBtn" DockPanel.Dock="Right" Content="Copy" Click="CopyHex_Click" />
                    <TextBlock VerticalAlignment="Center" Style="{StaticResource Text.Section}" Text="HEX" />
                </DockPanel>
                <TextBox x:Name="HexBox" Margin="0,0,0,14" FontFamily="{StaticResource Font.Mono}" IsReadOnly="True" />

                <DockPanel Margin="0,0,0,6">
                    <Button x:Name="CopyRgbBtn" DockPanel.Dock="Right" Content="Copy" Click="CopyRgb_Click" />
                    <TextBlock VerticalAlignment="Center" Style="{StaticResource Text.Section}" Text="RGB" />
                </DockPanel>
                <TextBox x:Name="RgbBox" Margin="0,0,0,14" FontFamily="{StaticResource Font.Mono}" IsReadOnly="True" />

                <DockPanel Margin="0,0,0,6">
                    <Button x:Name="CopyHslBtn" DockPanel.Dock="Right" Content="Copy" Click="CopyHsl_Click" />
                    <TextBlock VerticalAlignment="Center" Style="{StaticResource Text.Section}" Text="HSL" />
                </DockPanel>
                <TextBox x:Name="HslBox" Margin="0,0,0,14" FontFamily="{StaticResource Font.Mono}" IsReadOnly="True" />

                <DockPanel Margin="0,0,0,6">
                    <Button x:Name="CopyHsbBtn" DockPanel.Dock="Right" Content="Copy" Click="CopyHsb_Click" />
                    <TextBlock VerticalAlignment="Center" Style="{StaticResource Text.Section}" Text="HSB" />
                </DockPanel>
                <TextBox x:Name="HsbBox" Margin="0,0,0,14" FontFamily="{StaticResource Font.Mono}" IsReadOnly="True" />

                <TextBlock x:Name="ContrastText" Style="{StaticResource Text.Sub}" />

                <TextBlock Margin="0,18,0,6" Style="{StaticResource Text.Section}" Text="HISTORY" />
                <TextBlock Margin="0,0,0,8"
                           Style="{StaticResource Text.Sub}"
                           Text="Colors picked from the screen this session. Click a swatch to reload it above." />
                <ItemsControl x:Name="HistoryStrip">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="26" Height="26"
                                    Margin="0,0,8,8"
                                    CornerRadius="6"
                                    BorderBrush="{StaticResource Brush.BorderStrong}"
                                    BorderThickness="1"
                                    Background="{Binding SwatchBrush}"
                                    Cursor="Hand"
                                    ToolTip="{Binding Hex}"
                                    MouseLeftButtonDown="HistorySwatch_MouseLeftButtonDown" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
