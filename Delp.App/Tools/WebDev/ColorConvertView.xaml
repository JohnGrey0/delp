<UserControl x:Class="Delp.App.Tools.WebDev.ColorConvertView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="16">
        <TabControl>

            <TabItem Header="CONVERT">
                <DockPanel Margin="0,10,0,0">

                    <TextBlock x:Name="ErrorText"
                               DockPanel.Dock="Bottom"
                               Margin="0,8,0,0"
                               Style="{StaticResource Text.Error}"
                               Visibility="Collapsed" />

                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>

                            <StackPanel Margin="0,0,0,16">
                                <Button x:Name="PickButton"
                                        Style="{StaticResource Button.Primary}"
                                        HorizontalAlignment="Left"
                                        Content="Pick from screen"
                                        Click="PickButton_Click" />
                                <TextBlock Margin="0,8,0,0"
                                           Style="{StaticResource Text.Sub}"
                                           Text="Multi-monitor supported. Esc cancels picking." />
                            </StackPanel>

                            <TextBlock Margin="0,0,0,6"
                                       Style="{StaticResource Text.Section}"
                                       Text="COLOR (#hex, rgb(), hsl(), hsb()/hsv())" />
                            <TextBox x:Name="InputBox"
                                     Margin="0,0,0,14"
                                     Text="#336699"
                                     TextChanged="InputBox_TextChanged" />

                            <WrapPanel Margin="0,0,0,4">
                                <Border x:Name="Swatch"
                                        Width="64" Height="64"
                                        Margin="0,0,18,10"
                                        BorderBrush="{StaticResource Brush.Border}"
                                        BorderThickness="1"
                                        CornerRadius="10" />

                                <StackPanel Margin="0,0,10,10" Orientation="Vertical" Width="60">
                                    <TextBlock Style="{StaticResource Text.Section}" Text="R" />
                                    <TextBox x:Name="RBox" TextChanged="Channel_TextChanged" />
                                </StackPanel>
                                <StackPanel Margin="0,0,10,10" Orientation="Vertical" Width="60">
                                    <TextBlock Style="{StaticResource Text.Section}" Text="G" />
                                    <TextBox x:Name="GBox" TextChanged="Channel_TextChanged" />
                                </StackPanel>
                                <StackPanel Margin="0,0,10,10" Orientation="Vertical" Width="60">
                                    <TextBlock Style="{StaticResource Text.Section}" Text="B" />
                                    <TextBox x:Name="BBox" TextChanged="Channel_TextChanged" />
                                </StackPanel>
                                <StackPanel Margin="0,0,10,10" Orientation="Vertical" Width="60">
                                    <TextBlock Style="{StaticResource Text.Section}" Text="A" />
                                    <TextBox x:Name="ABox" TextChanged="Channel_TextChanged" />
                                </StackPanel>
                            </WrapPanel>

                            <DockPanel Margin="0,10,0,6">
                                <Button x:Name="CopyHexBtn" DockPanel.Dock="Right" Content="Copy" Click="CopyHex_Click" />
                                <TextBlock VerticalAlignment="Center" Style="{StaticResource Text.Section}" Text="HEX" />
                            </DockPanel>
                            <TextBox x:Name="HexBox" Margin="0,0,0,14" FontFamily="{StaticResource Font.Mono}" IsReadOnly="True" />

                            <DockPanel Margin="0,0,0,6">
                                <Button x:Name="CopyRgbBtn" DockPanel.Dock="Right" Content="Copy" Click="CopyRgb_Click" />
                                <TextBlock VerticalAlignment="Center" Style="{StaticResource Text.Section}" Text="RGB" />
                            </DockPanel>
                            <TextBox x:Name="RgbBox" Margin="0,0,0,14" FontFamily="{StaticResource Font.Mono}" IsReadOnly="True" />

                            <DockPanel Margin="0,0,0,6">
                                <Button x:Name="CopyHslBtn" DockPanel.Dock="Right" Content="Copy" Click="CopyHsl_Click" />
                                <TextBlock VerticalAlignment="Center" Style="{StaticResource Text.Section}" Text="HSL" />
                            </DockPanel>
                            <TextBox x:Name="HslBox" Margin="0,0,0,14" FontFamily="{StaticResource Font.Mono}" IsReadOnly="True" />

                            <DockPanel Margin="0,0,0,6">
                                <Button x:Name="CopyHsbBtn" DockPanel.Dock="Right" Content="Copy" Click="CopyHsb_Click" />
                                <TextBlock VerticalAlignment="Center" Style="{StaticResource Text.Section}" Text="HSB" />
                            </DockPanel>
                            <TextBox x:Name="HsbBox" Margin="0,0,0,14" FontFamily="{StaticResource Font.Mono}" IsReadOnly="True" />

                            <TextBlock x:Name="ContrastText" Style="{StaticResource Text.Sub}" />

                            <TextBlock Margin="0,18,0,6" Style="{StaticResource Text.Section}" Text="HISTORY" />
                            <TextBlock Margin="0,0,0,8"
                                       Style="{StaticResource Text.Sub}"
                                       Text="Colors picked from the screen this session. Click a swatch to reload it above." />
                            <ItemsControl x:Name="HistoryStrip">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="26" Height="26"
                                                Margin="0,0,8,8"
                                                CornerRadius="6"
                                                BorderBrush="{StaticResource Brush.BorderStrong}"
                                                BorderThickness="1"
                                                Background="{Binding SwatchBrush}"
                                                Cursor="Hand"
                                                ToolTip="{Binding Hex}"
                                                MouseLeftButtonDown="HistorySwatch_MouseLeftButtonDown" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>

            <TabItem Header="CONTRAST">
                <DockPanel Margin="0,10,0,0">

                    <TextBlock x:Name="ContrastErrorText"
                               DockPanel.Dock="Bottom"
                               Margin="0,8,0,0"
                               Style="{StaticResource Text.Error}"
                               Visibility="Collapsed" />

                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>

                            <TextBlock Style="{StaticResource Text.Section}" Text="FOREGROUND" Margin="0,0,0,6" />
                            <WrapPanel Margin="0,0,0,14">
                                <Border x:Name="FgSwatch"
                                        Width="44" Height="44"
                                        Margin="0,0,12,8"
                                        BorderBrush="{StaticResource Brush.Border}"
                                        BorderThickness="1"
                                        CornerRadius="8" />
                                <TextBox x:Name="FgBox" Width="170" VerticalAlignment="Center" Margin="0,0,12,8" Text="#000000" TextChanged="Contrast_TextChanged" />
                                <Button Content="Pick from screen" VerticalAlignment="Center" Margin="0,0,0,8" Click="PickFg_Click" />
                            </WrapPanel>

                            <TextBlock Style="{StaticResource Text.Section}" Text="BACKGROUND" Margin="0,0,0,6" />
                            <WrapPanel Margin="0,0,0,18">
                                <Border x:Name="BgSwatch"
                                        Width="44" Height="44"
                                        Margin="0,0,12,8"
                                        BorderBrush="{StaticResource Brush.Border}"
                                        BorderThickness="1"
                                        CornerRadius="8" />
                                <TextBox x:Name="BgBox" Width="170" VerticalAlignment="Center" Margin="0,0,12,8" Text="#FFFFFF" TextChanged="Contrast_TextChanged" />
                                <Button Content="Pick from screen" VerticalAlignment="Center" Margin="0,0,0,8" Click="PickBg_Click" />
                            </WrapPanel>

                            <TextBlock x:Name="RatioText" Style="{StaticResource Text.Title}" Margin="0,0,0,12" Text="21.00 : 1" />

                            <WrapPanel Margin="0,0,0,18">
                                <Border Style="{StaticResource Card}" Margin="0,0,10,8" Padding="10,6">
                                    <TextBlock x:Name="AaNormalText" FontWeight="SemiBold" Text="AA normal (≥4.5:1)" />
                                </Border>
                                <Border Style="{StaticResource Card}" Margin="0,0,10,8" Padding="10,6">
                                    <TextBlock x:Name="AaLargeText" FontWeight="SemiBold" Text="AA large (≥3:1)" />
                                </Border>
                                <Border Style="{StaticResource Card}" Margin="0,0,10,8" Padding="10,6">
                                    <TextBlock x:Name="AaaNormalText" FontWeight="SemiBold" Text="AAA normal (≥7:1)" />
                                </Border>
                                <Border Style="{StaticResource Card}" Margin="0,0,10,8" Padding="10,6">
                                    <TextBlock x:Name="AaaLargeText" FontWeight="SemiBold" Text="AAA large (≥4.5:1)" />
                                </Border>
                            </WrapPanel>

                            <TextBlock Style="{StaticResource Text.Section}" Text="SAMPLE" Margin="0,0,0,6" />
                            <!-- Rendered with the user's own foreground/background colors, not theme brushes —
                                 that IS the point of a live contrast preview, so it is exempt from the
                                 theme-brush-only rule. -->
                            <Border x:Name="SampleBorder"
                                    Padding="16"
                                    CornerRadius="10"
                                    BorderBrush="{StaticResource Brush.Border}"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock x:Name="SampleLargeText" FontSize="24" FontWeight="SemiBold" Text="Large text sample Ag" />
                                    <TextBlock x:Name="SampleNormalText"
                                               Margin="0,10,0,0"
                                               FontSize="14"
                                               TextWrapping="Wrap"
                                               Text="Normal text sample — the quick brown fox jumps over the lazy dog." />
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>

            <TabItem Header="VISION">
                <DockPanel Margin="0,10,0,0">

                    <TextBlock x:Name="VisionErrorText"
                               DockPanel.Dock="Bottom"
                               Margin="0,8,0,0"
                               Style="{StaticResource Text.Error}"
                               Visibility="Collapsed" />

                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>

                            <TextBlock Margin="0,0,0,6"
                                       Style="{StaticResource Text.Section}"
                                       Text="COLOR (#hex, rgb(), hsl(), hsb()/hsv())" />
                            <WrapPanel Margin="0,0,0,18">
                                <Border x:Name="VisionSwatch"
                                        Width="44" Height="44"
                                        Margin="0,0,12,8"
                                        BorderBrush="{StaticResource Brush.Border}"
                                        BorderThickness="1"
                                        CornerRadius="8" />
                                <TextBox x:Name="VisionBox" Width="200" VerticalAlignment="Center" Margin="0,0,0,8" Text="#336699" TextChanged="Vision_TextChanged" />
                            </WrapPanel>

                            <TextBlock Style="{StaticResource Text.Sub}"
                                       Margin="0,0,0,14"
                                       Text="Simulates how the color above would appear under four kinds of color vision deficiency." />

                            <WrapPanel>
                                <StackPanel Margin="0,0,20,16" Width="110">
                                    <Border x:Name="ProtanopiaSwatch"
                                            Width="80" Height="80"
                                            BorderBrush="{StaticResource Brush.Border}"
                                            BorderThickness="1"
                                            CornerRadius="8" />
                                    <TextBlock Margin="0,6,0,0" Style="{StaticResource Text.Section}" Text="PROTANOPIA" />
                                    <TextBlock x:Name="ProtanopiaHex" Style="{StaticResource Text.Mono}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,20,16" Width="110">
                                    <Border x:Name="DeuteranopiaSwatch"
                                            Width="80" Height="80"
                                            BorderBrush="{StaticResource Brush.Border}"
                                            BorderThickness="1"
                                            CornerRadius="8" />
                                    <TextBlock Margin="0,6,0,0" Style="{StaticResource Text.Section}" Text="DEUTERANOPIA" />
                                    <TextBlock x:Name="DeuteranopiaHex" Style="{StaticResource Text.Mono}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,20,16" Width="110">
                                    <Border x:Name="TritanopiaSwatch"
                                            Width="80" Height="80"
                                            BorderBrush="{StaticResource Brush.Border}"
                                            BorderThickness="1"
                                            CornerRadius="8" />
                                    <TextBlock Margin="0,6,0,0" Style="{StaticResource Text.Section}" Text="TRITANOPIA" />
                                    <TextBlock x:Name="TritanopiaHex" Style="{StaticResource Text.Mono}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,20,16" Width="110">
                                    <Border x:Name="AchromatopsiaSwatch"
                                            Width="80" Height="80"
                                            BorderBrush="{StaticResource Brush.Border}"
                                            BorderThickness="1"
                                            CornerRadius="8" />
                                    <TextBlock Margin="0,6,0,0" Style="{StaticResource Text.Section}" Text="ACHROMATOPSIA" />
                                    <TextBlock x:Name="AchromatopsiaHex" Style="{StaticResource Text.Mono}" />
                                </StackPanel>
                            </WrapPanel>

                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>

        </TabControl>
    </DockPanel>
</UserControl>
