<UserControl x:Class="Delp.App.Tools.WebDev.MarkdownPreviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf">
    <DockPanel Margin="16">

        <TextBlock x:Name="ErrorText"
                   DockPanel.Dock="Bottom"
                   Margin="0,8,0,0"
                   Style="{StaticResource Text.Error}"
                   Visibility="Collapsed" />

        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <Button x:Name="CopyHtmlBtn"
                    DockPanel.Dock="Right"
                    Content="Copy HTML"
                    Click="CopyHtml_Click" />
            <TextBlock VerticalAlignment="Center"
                       Style="{StaticResource Text.Sub}"
                       Text="Live preview — script execution is disabled in the preview pane." />
        </DockPanel>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="150" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" MinWidth="150" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0"
                       Margin="0,0,0,6"
                       Style="{StaticResource Text.Section}"
                       Text="MARKDOWN" />
            <TextBlock Grid.Row="0" Grid.Column="2"
                       Margin="0,0,0,6"
                       Style="{StaticResource Text.Section}"
                       Text="PREVIEW" />

            <Border x:Name="EditorHost"
                    Grid.Row="1" Grid.Column="0"
                    Style="{StaticResource Card.Editor}" />

            <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource Card.Editor}">
                <Grid>
                    <wv2:WebView2 x:Name="Preview" />
                    <TextBlock x:Name="PreviewFallback"
                               Margin="8"
                               Style="{StaticResource Text.Sub}"
                               TextWrapping="Wrap"
                               Visibility="Collapsed" />
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
