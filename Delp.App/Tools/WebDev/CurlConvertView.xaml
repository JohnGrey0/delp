<UserControl x:Class="Delp.App.Tools.WebDev.CurlConvertView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="16">

        <TextBlock x:Name="ErrorText"
                   DockPanel.Dock="Bottom"
                   Margin="0,8,0,0"
                   Style="{StaticResource Text.Error}"
                   TextWrapping="Wrap"
                   Visibility="Collapsed" />

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" MinHeight="70" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" MinHeight="70" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Style="{StaticResource Text.Section}" Text="CURL COMMAND" Margin="0,0,0,4" />
            <TextBox x:Name="InputBox"
                     Grid.Row="1"
                     Style="{StaticResource TextBox.Mono}"
                     TextChanged="InputBox_TextChanged"
                     Margin="0,0,0,10" />

            <TextBlock Grid.Row="2" Style="{StaticResource Text.Section}" Text="BREAKDOWN" Margin="0,0,0,4" />
            <ItemsControl x:Name="BreakdownList" Grid.Row="3" Margin="0,0,0,10">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Card}" Padding="8,5" Margin="0,0,8,8">
                            <TextBlock Text="{Binding}"
                                       FontFamily="{StaticResource Font.Mono}"
                                       FontSize="12"
                                       Foreground="{StaticResource Brush.Fg1}" />
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <WrapPanel Grid.Row="4" Margin="0,0,0,10">
                <TextBlock Text="TARGET" VerticalAlignment="Center" Style="{StaticResource Text.Sub}" Margin="0,0,8,0" />
                <ComboBox x:Name="TargetCombo" Width="180" SelectedIndex="0" SelectionChanged="Target_Changed">
                    <ComboBoxItem Content="C# — HttpClient" />
                    <ComboBoxItem Content="Python — requests" />
                    <ComboBoxItem Content="JavaScript — fetch" />
                    <ComboBoxItem Content="PowerShell — Invoke-RestMethod" />
                    <ComboBoxItem Content="Go — net/http" />
                </ComboBox>
            </WrapPanel>

            <DockPanel Grid.Row="5" Margin="0,0,0,6">
                <Button x:Name="CopyOutputBtn" DockPanel.Dock="Right" Content="Copy" Click="CopyOutput_Click" />
                <TextBlock VerticalAlignment="Center" Style="{StaticResource Text.Section}" Text="OUTPUT" />
            </DockPanel>
            <Border x:Name="OutputHost" Grid.Row="6" Style="{StaticResource Card.Editor}" />
        </Grid>
    </DockPanel>
</UserControl>
