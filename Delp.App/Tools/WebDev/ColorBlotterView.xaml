<UserControl x:Class="Delp.App.Tools.WebDev.ColorBlotterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="16">

        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <Button x:Name="PickButton"
                    Style="{StaticResource Button.Primary}"
                    HorizontalAlignment="Left"
                    Content="Pick from screen"
                    Click="PickButton_Click" />
            <TextBlock Margin="0,8,0,0"
                       Style="{StaticResource Text.Sub}"
                       Text="Multi-monitor supported. Esc cancels picking." />
        </StackPanel>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Current color -->
            <Border Grid.Row="0" Style="{StaticResource Card}" Padding="14" Margin="0,0,0,14">
                <WrapPanel>
                    <Border x:Name="CurrentSwatch"
                            Width="72" Height="72"
                            Margin="0,0,16,8"
                            CornerRadius="10"
                            BorderBrush="{StaticResource Brush.BorderStrong}"
                            BorderThickness="1" />

                    <StackPanel MinWidth="240" VerticalAlignment="Center">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="42" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource Text.Section}" VerticalAlignment="Center" Text="HEX" />
                            <TextBox x:Name="HexBox" Grid.Column="1" Margin="8,0" IsReadOnly="True"
                                     FontFamily="{StaticResource Font.Mono}" VerticalContentAlignment="Center" />
                            <Button Grid.Column="2" Content="Copy" Click="CopyHex_Click" />
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="42" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource Text.Section}" VerticalAlignment="Center" Text="RGB" />
                            <TextBox x:Name="RgbBox" Grid.Column="1" Margin="8,0" IsReadOnly="True"
                                     FontFamily="{StaticResource Font.Mono}" VerticalContentAlignment="Center" />
                            <Button Grid.Column="2" Content="Copy" Click="CopyRgb_Click" />
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="42" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource Text.Section}" VerticalAlignment="Center" Text="HSL" />
                            <TextBox x:Name="HslBox" Grid.Column="1" Margin="8,0" IsReadOnly="True"
                                     FontFamily="{StaticResource Font.Mono}" VerticalContentAlignment="Center" />
                            <Button Grid.Column="2" Content="Copy" Click="CopyHsl_Click" />
                        </Grid>
                    </StackPanel>
                </WrapPanel>
            </Border>

            <TextBlock Grid.Row="1" Style="{StaticResource Text.Section}" Margin="0,0,0,6" Text="HISTORY" />

            <Border Grid.Row="2" Style="{StaticResource Card.Editor}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ListBox x:Name="HistoryList"
                             BorderThickness="0"
                             SelectionChanged="HistoryList_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="2,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0"
                                            Width="24" Height="24"
                                            CornerRadius="5"
                                            BorderBrush="{StaticResource Brush.BorderStrong}"
                                            BorderThickness="1"
                                            Background="{Binding SwatchBrush}" />
                                    <TextBlock Grid.Column="1"
                                               Margin="10,0"
                                               VerticalAlignment="Center"
                                               FontFamily="{StaticResource Font.Mono}"
                                               FontSize="12.5"
                                               Foreground="{StaticResource Brush.Fg1}"
                                               Text="{Binding Hex}" />
                                    <Button Grid.Column="2"
                                            Style="{StaticResource Button.Icon}"
                                            Content="Copy"
                                            Click="CopyHistoryItem_Click" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
