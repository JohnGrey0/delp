<UserControl x:Class="Delp.App.Tools.TextProcessing.StringEscapeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="16">

        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
            <TextBlock VerticalAlignment="Center"
                       Margin="0,0,10,0"
                       Style="{StaticResource Text.Section}"
                       Text="TARGET" />
            <ComboBox x:Name="TargetBox"
                      Width="220"
                      HorizontalAlignment="Left"
                      SelectionChanged="TargetBox_SelectionChanged" />
        </DockPanel>

        <WrapPanel x:Name="HtmlEntitiesOptions"
                   DockPanel.Dock="Top"
                   Margin="0,0,0,10"
                   Visibility="Collapsed">
            <CheckBox x:Name="NumericEntitiesBox"
                      Content="Encode non-ASCII as numeric entities"
                      Checked="Option_Changed"
                      Unchecked="Option_Changed" />
        </WrapPanel>

        <WrapPanel x:Name="UnicodeOptions"
                   DockPanel.Dock="Top"
                   Margin="0,0,0,10"
                   Visibility="Collapsed">
            <CheckBox x:Name="NonAsciiOnlyBox"
                      Content="Escape non-ASCII only"
                      IsChecked="True"
                      Checked="Option_Changed"
                      Unchecked="Option_Changed" />
        </WrapPanel>

        <TextBlock x:Name="ErrorText"
                   DockPanel.Dock="Bottom"
                   Margin="0,8,0,0"
                   Style="{StaticResource Text.Error}"
                   Visibility="Collapsed" />

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,6">
                <Button x:Name="CopyPlainBtn" DockPanel.Dock="Right" Content="Copy" Click="CopyPlain_Click" />
                <TextBlock VerticalAlignment="Center" Style="{StaticResource Text.Section}" Text="PLAIN" />
            </DockPanel>
            <TextBox x:Name="PlainBox"
                     Grid.Row="1"
                     Style="{StaticResource TextBox.Mono}"
                     MinHeight="64"
                     TextChanged="PlainBox_TextChanged" />

            <DockPanel Grid.Row="2" Margin="0,14,0,6">
                <Button x:Name="CopyEscapedBtn" DockPanel.Dock="Right" Content="Copy" Click="CopyEscaped_Click" />
                <TextBlock VerticalAlignment="Center" Style="{StaticResource Text.Section}" Text="ESCAPED" />
            </DockPanel>
            <TextBox x:Name="EscapedBox"
                     Grid.Row="3"
                     Style="{StaticResource TextBox.Mono}"
                     MinHeight="64"
                     TextChanged="EscapedBox_TextChanged" />
        </Grid>
    </DockPanel>
</UserControl>
