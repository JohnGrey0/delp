<UserControl x:Class="Delp.App.Tools.TextProcessing.UnicodeInspectView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="16">

        <TextBlock Style="{StaticResource Text.Section}" DockPanel.Dock="Top" Margin="0,0,0,6" Text="INPUT" />
        <TextBox x:Name="InputBox"
                 DockPanel.Dock="Top"
                 Style="{StaticResource TextBox.Mono}"
                 MinHeight="56"
                 MaxHeight="110"
                 Margin="0,0,0,10"
                 TextChanged="InputBox_TextChanged" />

        <TextBlock x:Name="SummaryText"
                   DockPanel.Dock="Top"
                   Style="{StaticResource Text.Sub}"
                   Margin="0,0,0,10" />

        <TextBlock x:Name="ErrorText"
                   DockPanel.Dock="Bottom"
                   Margin="0,8,0,0"
                   Style="{StaticResource Text.Error}"
                   Visibility="Collapsed" />

        <TextBlock x:Name="CapNoteText"
                   DockPanel.Dock="Bottom"
                   Margin="0,4,0,0"
                   Style="{StaticResource Text.Sub}"
                   Visibility="Collapsed" />

        <Border Style="{StaticResource Card.Editor}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <Grid Margin="8,4,8,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44" />
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource Text.Section}" Text="GLYPH" />
                        <TextBlock Grid.Column="1" Style="{StaticResource Text.Section}" Text="CODEPOINT" />
                        <TextBlock Grid.Column="2" Style="{StaticResource Text.Section}" Text="UTF-8" />
                        <TextBlock Grid.Column="3" Style="{StaticResource Text.Section}" Text="CATEGORY" />
                    </Grid>

                    <ItemsControl x:Name="RowsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="8,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="44" />
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0"
                                            Width="28" Height="28"
                                            HorizontalAlignment="Left"
                                            Style="{StaticResource Card}">
                                        <TextBlock Text="{Binding GlyphDisplay}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="{Binding GlyphFontSize}"
                                                   Foreground="{Binding GlyphBrush}" />
                                    </Border>
                                    <TextBlock Grid.Column="1" Style="{StaticResource Text.Mono}" VerticalAlignment="Center" Text="{Binding CodepointHex}" />
                                    <TextBlock Grid.Column="2" Style="{StaticResource Text.Mono}" VerticalAlignment="Center" Text="{Binding Utf8Hex}" TextWrapping="Wrap" />
                                    <TextBlock Grid.Column="3" VerticalAlignment="Center" Foreground="{Binding CategoryBrush}" Text="{Binding CategoryDisplay}" TextWrapping="Wrap" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </DockPanel>
</UserControl>
