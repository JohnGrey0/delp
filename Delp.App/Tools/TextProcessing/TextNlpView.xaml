<UserControl x:Class="Delp.App.Tools.TextProcessing.TextNlpView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <DataTemplate x:Key="RowTemplate">
            <TextBlock Margin="4,3"
                       FontFamily="{StaticResource Font.Mono}"
                       FontSize="12.5"
                       Foreground="{StaticResource Brush.Fg0}"
                       Text="{Binding}"
                       TextTrimming="CharacterEllipsis" />
        </DataTemplate>
    </UserControl.Resources>
    <DockPanel Margin="16">

        <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,10">
            <CheckBox x:Name="LowercaseBox" Content="Lowercase" Margin="0,0,14,6" IsChecked="True" Checked="Options_Changed" Unchecked="Options_Changed" />
            <CheckBox x:Name="StopwordsBox" Content="Remove stopwords" Margin="0,0,14,6" IsChecked="True" Checked="Options_Changed" Unchecked="Options_Changed" />
            <CheckBox x:Name="PunctuationBox" Content="Remove punctuation" Margin="0,0,14,6" Checked="Options_Changed" Unchecked="Options_Changed" />
            <CheckBox x:Name="NumbersBox" Content="Remove numbers" Margin="0,0,14,6" Checked="Options_Changed" Unchecked="Options_Changed" />
            <CheckBox x:Name="StemBox" Content="Stem (Porter)" Margin="0,0,14,6" IsChecked="True" Checked="Options_Changed" Unchecked="Options_Changed" />
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock VerticalAlignment="Center" Style="{StaticResource Text.Section}" Text="EXTRA STOPWORDS" Margin="0,0,8,0" />
                <TextBox x:Name="ExtraStopwordsBox" Width="180" Tag="e.g. foo, bar" TextChanged="ExtraStopwords_TextChanged" />
            </StackPanel>
        </WrapPanel>

        <TextBlock x:Name="ErrorText"
                   DockPanel.Dock="Bottom"
                   Margin="0,8,0,0"
                   Style="{StaticResource Text.Error}"
                   Visibility="Collapsed" />

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="2*" MinHeight="90" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="3*" MinHeight="140" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,10">
                <TextBlock DockPanel.Dock="Top" Margin="0,0,0,6" Style="{StaticResource Text.Section}" Text="INPUT" />
                <TextBox x:Name="InputBox"
                         Style="{StaticResource TextBox.Mono}"
                         AcceptsTab="False"
                         TextChanged="InputBox_TextChanged"
                         Text="The quick brown foxes jumped over the lazy dogs. Foxes are running; dogs are sleeping." />
            </DockPanel>

            <TextBlock x:Name="StatusText"
                       Grid.Row="1"
                       Margin="0,0,0,8"
                       Style="{StaticResource Text.Sub}"
                       Text="0 tokens · 0 unique · 0 sentences" />

            <TabControl Grid.Row="2">
                <TabItem Header="PROCESSED">
                    <DockPanel>
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                            <Button x:Name="CopyProcessedBtn" DockPanel.Dock="Right" Content="Copy" Click="CopyProcessed_Click" />
                            <TextBlock VerticalAlignment="Center" Style="{StaticResource Text.Section}" Text="PROCESSED TEXT" />
                        </DockPanel>
                        <TextBox x:Name="ProcessedBox" Style="{StaticResource TextBox.Mono}" IsReadOnly="True" />
                    </DockPanel>
                </TabItem>

                <TabItem Header="TOKENS">
                    <DockPanel>
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                            <Button x:Name="CopyTokensBtn" DockPanel.Dock="Right" Content="Copy" Click="CopyTokens_Click" />
                            <TextBlock VerticalAlignment="Center" Style="{StaticResource Text.Section}" Text="TOKENS (ONE PER LINE)" />
                        </DockPanel>
                        <TextBox x:Name="TokensBox" Style="{StaticResource TextBox.Mono}" IsReadOnly="True" />
                    </DockPanel>
                </TabItem>

                <TabItem Header="FREQUENCIES">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Margin="0,0,0,6" Style="{StaticResource Text.Section}" Text="TOP 100 BY COUNT" />
                        <Border Style="{StaticResource Card.Editor}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="FrequencyList" ItemTemplate="{StaticResource RowTemplate}" />
                            </ScrollViewer>
                        </Border>
                    </DockPanel>
                </TabItem>

                <TabItem Header="BIGRAMS">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Margin="0,0,0,6" Style="{StaticResource Text.Section}" Text="TOP 50 BY COUNT" />
                        <Border Style="{StaticResource Card.Editor}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="BigramList" ItemTemplate="{StaticResource RowTemplate}" />
                            </ScrollViewer>
                        </Border>
                    </DockPanel>
                </TabItem>

                <TabItem Header="TRIGRAMS">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Margin="0,0,0,6" Style="{StaticResource Text.Section}" Text="TOP 50 BY COUNT" />
                        <Border Style="{StaticResource Card.Editor}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="TrigramList" ItemTemplate="{StaticResource RowTemplate}" />
                            </ScrollViewer>
                        </Border>
                    </DockPanel>
                </TabItem>
            </TabControl>
        </Grid>
    </DockPanel>
</UserControl>
