<UserControl x:Class="Delp.App.Tools.TextProcessing.RegexLibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="16">
        <TextBox x:Name="SearchBox"
                 DockPanel.Dock="Top"
                 Style="{StaticResource TextBox.Search}"
                 Tag="Search patterns…"
                 Margin="0,0,0,12"
                 TextChanged="SearchBox_TextChanged" />

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <ListBox x:Name="EntryList" SelectionChanged="EntryList_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock FontSize="13" Text="{Binding Name}" TextWrapping="Wrap" />
                                <TextBlock FontSize="11"
                                           Foreground="{StaticResource Brush.Fg2}"
                                           Text="{Binding Category}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ScrollViewer>

            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="DetailPanel">
                    <TextBlock x:Name="DetailName" Style="{StaticResource Text.Title}" FontSize="16" TextWrapping="Wrap" />
                    <TextBlock x:Name="DetailDescription" Style="{StaticResource Text.Sub}" Margin="0,4,0,0" />

                    <TextBlock Text="PATTERN" Style="{StaticResource Text.Section}" Margin="0,16,0,4" />
                    <DockPanel>
                        <Button DockPanel.Dock="Right" x:Name="CopyPatternBtn" Content="Copy" Click="CopyPattern_Click" />
                        <TextBox x:Name="PatternBox" Style="{StaticResource TextBox.Mono}" MinHeight="0" IsReadOnly="True" Margin="0,0,8,0" />
                    </DockPanel>

                    <TextBlock Text="EXAMPLE" Style="{StaticResource Text.Section}" Margin="0,14,0,4" />
                    <TextBox x:Name="ExampleBox" Style="{StaticResource TextBox.Mono}" MinHeight="0" IsReadOnly="True" />

                    <TextBlock x:Name="MatchStatusText" Margin="0,8,0,0" FontSize="12" />
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</UserControl>
