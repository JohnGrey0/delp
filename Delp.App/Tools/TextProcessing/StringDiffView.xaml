<UserControl x:Class="Delp.App.Tools.TextProcessing.StringDiffView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Top">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="OLD" Style="{StaticResource Text.Section}" Margin="0,0,0,4" />
                    <TextBox x:Name="OldBox"
                             Style="{StaticResource TextBox.Mono}"
                             MinHeight="100" MaxHeight="150"
                             TextChanged="Input_Changed" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="NEW" Style="{StaticResource Text.Section}" Margin="0,0,0,4" />
                    <TextBox x:Name="NewBox"
                             Style="{StaticResource TextBox.Mono}"
                             MinHeight="100" MaxHeight="150"
                             TextChanged="Input_Changed" />
                </StackPanel>
            </Grid>

            <WrapPanel Margin="0,10,0,0">
                <CheckBox x:Name="IgnoreCaseBox" Content="Ignore case" Margin="0,0,14,4"
                          Checked="Input_Changed" Unchecked="Input_Changed" />
                <CheckBox x:Name="IgnoreWhitespaceBox" Content="Ignore whitespace" Margin="0,0,14,4"
                          Checked="Input_Changed" Unchecked="Input_Changed" />
            </WrapPanel>

            <TextBlock Text="DIFF" Style="{StaticResource Text.Section}" Margin="0,10,0,4" />
        </StackPanel>

        <TextBlock x:Name="StatusText"
                   DockPanel.Dock="Bottom"
                   Style="{StaticResource Text.Sub}"
                   Margin="0,8,0,0" />
        <TextBlock x:Name="ErrorText"
                   DockPanel.Dock="Bottom"
                   Style="{StaticResource Text.Error}"
                   Visibility="Collapsed" />

        <!-- One virtualized ListBox with a paired-row template (rather than two plain
             ItemsControls sharing a ScrollViewer) so a 10k-line diff realizes only the
             rows currently on screen instead of laying out every row up front. -->
        <ListBox x:Name="DiffList">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                    <Setter Property="Padding" Value="0" />
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="1" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="{Binding OldBackground}" Padding="4,2">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Left"
                                           Text="{Binding OldNumber}"
                                           Width="36"
                                           TextAlignment="Right"
                                           Margin="0,0,8,0"
                                           Foreground="{StaticResource Brush.Fg2}"
                                           FontFamily="{StaticResource Font.Mono}"
                                           FontSize="12" />
                                <TextBlock Text="{Binding OldText}"
                                           TextWrapping="Wrap"
                                           FontFamily="{StaticResource Font.Mono}"
                                           FontSize="13"
                                           Foreground="{StaticResource Brush.Fg0}" />
                            </DockPanel>
                        </Border>

                        <Border Grid.Column="1" Background="{StaticResource Brush.Border}" />

                        <Border Grid.Column="2" Background="{Binding NewBackground}" Padding="4,2">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Left"
                                           Text="{Binding NewNumber}"
                                           Width="36"
                                           TextAlignment="Right"
                                           Margin="0,0,8,0"
                                           Foreground="{StaticResource Brush.Fg2}"
                                           FontFamily="{StaticResource Font.Mono}"
                                           FontSize="12" />
                                <TextBlock Text="{Binding NewText}"
                                           TextWrapping="Wrap"
                                           FontFamily="{StaticResource Font.Mono}"
                                           FontSize="13"
                                           Foreground="{StaticResource Brush.Fg0}" />
                            </DockPanel>
                        </Border>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</UserControl>
