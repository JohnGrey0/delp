<UserControl x:Class="Delp.App.Tools.TextProcessing.UrlSlugView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="16">

        <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" Margin="0,0,18,6">
                <RadioButton x:Name="HyphenBox" Content="-" GroupName="Sep" IsChecked="True" Margin="0,0,10,0" Checked="Option_Changed" />
                <RadioButton x:Name="UnderscoreBox" Content="_" GroupName="Sep" Checked="Option_Changed" />
            </StackPanel>
            <CheckBox x:Name="LowercaseBox" Content="Lowercase" IsChecked="True" Margin="0,0,16,6" Checked="Option_Changed" Unchecked="Option_Changed" />
            <CheckBox x:Name="RemoveStopwordsBox" Content="Remove stopwords" Margin="0,0,16,6" Checked="Option_Changed" Unchecked="Option_Changed" />
            <StackPanel Orientation="Horizontal" Margin="0,0,16,6">
                <TextBlock VerticalAlignment="Center" Margin="0,0,6,0" Style="{StaticResource Text.Sub}" Text="Max length" />
                <TextBox x:Name="MaxLengthBox" Width="60" TextChanged="Option_Changed" />
            </StackPanel>
        </WrapPanel>

        <TextBlock x:Name="ErrorText"
                   DockPanel.Dock="Bottom"
                   Margin="0,8,0,0"
                   Style="{StaticResource Text.Error}"
                   Visibility="Collapsed" />

        <StackPanel VerticalAlignment="Top">
            <TextBlock Style="{StaticResource Text.Section}" Text="INPUT" Margin="0,0,0,6" />
            <TextBox x:Name="InputBox" Margin="0,0,0,16" TextChanged="InputBox_TextChanged" />

            <DockPanel Margin="0,0,0,6">
                <Button x:Name="CopyBtn" DockPanel.Dock="Right" Content="Copy" Click="Copy_Click" />
                <TextBlock VerticalAlignment="Center" Style="{StaticResource Text.Section}" Text="SLUG" />
            </DockPanel>
            <TextBox x:Name="OutputBox" FontFamily="{StaticResource Font.Mono}" IsReadOnly="True" />
        </StackPanel>
    </DockPanel>
</UserControl>
