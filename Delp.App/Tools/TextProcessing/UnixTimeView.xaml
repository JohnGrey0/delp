<UserControl x:Class="Delp.App.Tools.TextProcessing.UnixTimeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="UnixTimeView_Loaded"
             Unloaded="UnixTimeView_Unloaded">
    <DockPanel Margin="16">
        <TabControl>
            <TabItem Header="CONVERT">
                <DockPanel Margin="0,10,0,0">

        <TextBlock x:Name="ErrorText"
                   DockPanel.Dock="Bottom"
                   Margin="0,8,0,0"
                   Style="{StaticResource Text.Error}"
                   Visibility="Collapsed" />

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- NOW card -->
                <Border Style="{StaticResource Card}" Padding="14" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Style="{StaticResource Text.Section}" Text="NOW" Margin="0,0,0,8" />
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="NowSecondsText" Style="{StaticResource Text.Mono}" VerticalAlignment="Center" />
                            <Button x:Name="CopyNowSecondsBtn" Grid.Column="1" Content="Copy s" Click="CopyNowSeconds_Click" />
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="NowMillisText" Style="{StaticResource Text.Mono}" VerticalAlignment="Center" />
                            <Button x:Name="CopyNowMillisBtn" Grid.Column="1" Content="Copy ms" Click="CopyNowMillis_Click" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- EPOCH -> DATE -->
                <TextBlock Style="{StaticResource Text.Section}" Text="EPOCH → DATE" Margin="0,0,0,6" />
                <DockPanel Margin="0,0,0,6">
                    <ComboBox x:Name="UnitBox" DockPanel.Dock="Right" Width="90" SelectionChanged="EpochUnit_Changed" />
                    <TextBox x:Name="EpochInputBox" Margin="0,0,10,0" TextChanged="EpochInputBox_TextChanged" />
                </DockPanel>
                <TextBlock x:Name="DetectedUnitText" Style="{StaticResource Text.Sub}" Margin="0,0,0,10" />

                <Border Style="{StaticResource Card}" Padding="12" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Style="{StaticResource Text.Sub}" Text="Local" />
                        <TextBlock x:Name="LocalIsoText" Style="{StaticResource Text.Mono}" Margin="0,0,0,8" TextWrapping="Wrap" />
                        <TextBlock Style="{StaticResource Text.Sub}" Text="UTC" />
                        <TextBlock x:Name="UtcIsoText" Style="{StaticResource Text.Mono}" Margin="0,0,0,8" TextWrapping="Wrap" />
                        <TextBlock Style="{StaticResource Text.Sub}" Text="RFC 1123" />
                        <TextBlock x:Name="Rfc1123Text" Style="{StaticResource Text.Mono}" Margin="0,0,0,8" TextWrapping="Wrap" />
                        <TextBlock Style="{StaticResource Text.Sub}" Text="Relative" />
                        <TextBlock x:Name="RelativeText" Style="{StaticResource Text.Mono}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- DATE -> EPOCH -->
                <TextBlock Style="{StaticResource Text.Section}" Text="DATE → EPOCH" Margin="0,0,0,6" />
                <DockPanel Margin="0,0,0,10">
                    <Button x:Name="NowButton" DockPanel.Dock="Right" Content="Now" Click="NowButton_Click" />
                    <TextBox x:Name="DateInputBox" Margin="0,0,10,0" Tag="ISO 8601 or yyyy-MM-dd HH:mm:ss" TextChanged="DateInputBox_TextChanged" />
                </DockPanel>
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="DateSecondsText" Style="{StaticResource Text.Mono}" VerticalAlignment="Center" />
                    <Button x:Name="CopyDateSecondsBtn" Grid.Column="1" Content="Copy s" Click="CopyDateSeconds_Click" />
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="DateMillisText" Style="{StaticResource Text.Mono}" VerticalAlignment="Center" />
                    <Button x:Name="CopyDateMillisBtn" Grid.Column="1" Content="Copy ms" Click="CopyDateMillis_Click" />
                </Grid>
            </StackPanel>
        </ScrollViewer>
                </DockPanel>
            </TabItem>

            <TabItem Header="BATCH">
                <DockPanel Margin="0,10,0,0">

                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                        <TextBlock VerticalAlignment="Center"
                                   Margin="0,0,10,0"
                                   Style="{StaticResource Text.Section}"
                                   Text="UNIT" />
                        <ComboBox x:Name="BatchUnitBox" Width="90" HorizontalAlignment="Left" SelectionChanged="BatchOption_Changed" />
                    </DockPanel>

                    <TextBlock x:Name="BatchStatusText"
                               DockPanel.Dock="Bottom"
                               Margin="0,8,0,0"
                               Style="{StaticResource Text.Sub}" />

                    <TextBlock x:Name="BatchErrorText"
                               DockPanel.Dock="Bottom"
                               Margin="0,4,0,0"
                               Style="{StaticResource Text.Error}"
                               Visibility="Collapsed" />

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="1.4*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Margin="0,0,0,6" Style="{StaticResource Text.Section}" Text="INPUT (one timestamp per line)" />
                        <TextBox x:Name="BatchInputBox"
                                 Grid.Row="1"
                                 Style="{StaticResource TextBox.Mono}"
                                 MinHeight="64"
                                 TextChanged="BatchInputBox_TextChanged" />

                        <DockPanel Grid.Row="2" Margin="0,14,0,6">
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <Button x:Name="BatchCopyCsvBtn" Content="Copy CSV" Margin="6,0,0,0" Click="BatchCopyCsv_Click" />
                                <Button x:Name="BatchCopyTableBtn" Content="Copy table" Margin="6,0,0,0" Click="BatchCopyTable_Click" />
                            </StackPanel>
                            <TextBlock VerticalAlignment="Center" Style="{StaticResource Text.Section}" Text="OUTPUT" />
                        </DockPanel>
                        <TextBox x:Name="BatchOutputBox"
                                 Grid.Row="3"
                                 Style="{StaticResource TextBox.Mono}"
                                 MinHeight="80"
                                 IsReadOnly="True"
                                 TextWrapping="NoWrap"
                                 HorizontalScrollBarVisibility="Auto" />
                    </Grid>
                </DockPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</UserControl>
