<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="Delp"
           Manufacturer="Delp"
           Version="1.1.0"
           Language="1033"
           Scope="perUser"
           UpgradeCode="36197196-79de-40d2-ae46-095d12bc652d">

    <MajorUpgrade AllowSameVersionUpgrades="yes"
                  DowngradeErrorMessage="A newer version of Delp is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Icon Id="DelpIcon" SourceFile="..\Delp.App\Assets\delp.ico" />
    <Property Id="ARPPRODUCTICON" Value="DelpIcon" />

    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />
    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />

    <!-- "Launch Delp now" checkbox on the finish page (checked by default). -->
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT" Value="Launch Delp now" />
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOX" Value="1" />
    <Property Id="WixShellExecTarget" Value="[INSTALLFOLDER]delp.exe" />
    <CustomAction Id="LaunchApplication"
                  DllEntry="WixShellExec"
                  Impersonate="yes"
                  BinaryRef="Wix4UtilCA_X64" />
    <UI>
      <Publish Dialog="ExitDialog"
               Control="Finish"
               Event="DoAction"
               Value="LaunchApplication"
               Condition="WIXUI_EXITDIALOGOPTIONALCHECKBOX = 1 and NOT Installed" />
    </UI>

    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Name="Programs">
        <Directory Id="INSTALLFOLDER" Name="Delp">
          <Files Include="$(PublishDir)\**" />
        </Directory>
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder" />

    <Component Directory="INSTALLFOLDER" Id="StartMenuShortcut"
               Guid="8c3135f8-f040-4047-835e-5a544d82cc8d">
      <Shortcut Id="DelpStartMenuShortcut"
                Directory="ProgramMenuFolder"
                Name="Delp"
                Description="Developer toolbox â€” 75 tools in your tray"
                Target="[INSTALLFOLDER]delp.exe"
                WorkingDirectory="INSTALLFOLDER"
                Icon="DelpIcon" />
      <RemoveFolder Id="CleanInstallFolder" Directory="INSTALLFOLDER" On="uninstall" />
      <RegistryValue Root="HKCU" Key="Software\Delp" Name="installed"
                     Type="integer" Value="1" KeyPath="yes" />
    </Component>

  </Package>
</Wix>
